---
/**
 * Persistent dashboard shell for authenticated routes.
 *
 *   ┌──────────┬─────────────────────────────────┐
 *   │ sidebar  │ topbar (search · bell · me)     │  56px
 *   │ 240px    ├─────────────────────────────────┤
 *   │ fixed    │ <slot>                          │
 *   │ nav      │                                 │
 *   └──────────┴─────────────────────────────────┘
 *
 * Below 1024px the sidebar collapses to a drawer; topbar shrinks.
 *
 * The shell is a server-rendered Astro layout (zero JS for nav itself).
 * Only the user-menu dropdown is a React island.
 */
import BaseLayout from "./BaseLayout.astro";
import { AppUserMenu } from "../components/AppUserMenu";
import { SidebarNotifBadge } from "../components/SidebarNotifBadge";
import { GlobalSearch } from "../components/GlobalSearch";
import {
  Compass,
  Home,
  CalendarDays,
  Users,
  Layers,
  Tag,
  Building2,
  FileText,
  Newspaper,
  Headphones,
  ShoppingBag,
  CreditCard,
  Receipt,
  Ticket,
  Bell,
  ClipboardCheck,
  FileEdit,
  Mail,
  Wallet,
} from "lucide-react";

interface Props {
  title: string;
  pageTitle?: string;
}

const { title, pageTitle } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

type NavItem = {
  href: string;
  label: string;
  icon: any;
};
type NavSection = {
  label: string;
  items: NavItem[];
};

const sections: NavSection[] = [
  {
    label: "Comunità",
    items: [
      { href: "/today", label: "Today", icon: Home },
      { href: "/discover", label: "Esplora", icon: Compass },
      { href: "/events", label: "Eventi", icon: CalendarDays },
      { href: "/members", label: "Registro Soci", icon: Users },
      { href: "/sigs", label: "SIG e gruppi", icon: Layers },
      { href: "/deals", label: "Convenzioni", icon: Tag },
      { href: "/chapters", label: "Gruppi locali", icon: Building2 },
    ],
  },
  {
    label: "Risorse e profilo",
    items: [
      { href: "/documents", label: "Documenti", icon: FileText },
      { href: "/quid", label: "Quid", icon: Newspaper },
      { href: "/podcasts", label: "Podcasts", icon: Headphones },
      { href: "/boutique", label: "Boutique", icon: ShoppingBag },
      { href: "/card", label: "Tessera", icon: CreditCard },
      { href: "/tickets", label: "Biglietti", icon: Ticket },
      { href: "/receipts", label: "Ricevute", icon: Receipt },
      { href: "/notifications", label: "Notifiche", icon: Bell },
    ],
  },
  {
    label: "Gestione",
    items: [
      { href: "/console/test-assistant/today", label: "Test",           icon: ClipboardCheck },
      { href: "/console/newsletter",           label: "Newsletter",     icon: Mail           },
      { href: "/keystatic",                    label: "Blogging",       icon: FileEdit       },
      { href: "/console/ledger",              label: "Conto economico", icon: Wallet         },
    ],
  },
];

---

<BaseLayout title={title}>
  <div class="shell">
    <!-- Mobile hamburger toggle target — pure-CSS via :checked sibling combinator -->
    <input type="checkbox" id="mobile-nav-toggle" class="shell__mobile-toggle" />

    <aside class="shell__sidebar" aria-label="Navigazione principale">
      <div class="shell__brand">
        <a href="/today" class="shell__brand-link">
          <img
            src="/mensa-logo.svg"
            alt=""
            class="shell__brand-mark"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="shell__brand-name">Mensa Italia</span>
        </a>
      </div>

      <nav class="shell__nav">
        {
          sections.map((section) => (
            <div
              class="shell__nav-section"
              data-super-only={section.label === "Gestione" ? "" : undefined}
              style={section.label === "Gestione" ? "display: none" : undefined}
            >
              <p class="shell__nav-label">{section.label}</p>
              <ul class="shell__nav-list">
                {section.items.map((item) => {
                  const active = currentPath === item.href || currentPath.startsWith(item.href + "/");
                  const isNotifs = item.href === "/notifications";
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`shell__nav-item${active ? " shell__nav-item--active" : ""}`}
                        aria-current={active ? "page" : undefined}
                      >
                        <item.icon size={16} strokeWidth={1.75} aria-hidden="true" />
                        <span>{item.label}</span>
                        {isNotifs && <SidebarNotifBadge client:only="react" />}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>

      <div class="shell__sidebar-footer">
        <p>the high I.Q. society</p>
        <p>dal 1946</p>
      </div>
    </aside>

    <script is:inline>
      (function () {
        function applySuperVisibility() {
          try {
            var raw = localStorage.getItem("mensa.auth.user");
            if (!raw) return;
            var user = JSON.parse(raw);
            var powers = user && user.powers;
            if (!Array.isArray(powers)) return;
            if (powers.indexOf("super") === -1 && powers.indexOf("admin") === -1) return;
            document.querySelectorAll("[data-super-only]").forEach(function (el) {
              el.style.display = "";
            });
          } catch (_) {}
        }
        applySuperVisibility();
        document.addEventListener("astro:page-load", applySuperVisibility);
      })();
    </script>

    <div class="shell__main">
      <header class="shell__topbar">
        <label
          for="mobile-nav-toggle"
          class="shell__hamburger"
          aria-label="Apri navigazione"
        >
          <span></span>
          <span></span>
          <span></span>
        </label>

        <div class="shell__page-title" aria-live="polite">
          {pageTitle ?? title}
        </div>

        <div class="shell__search">
          <GlobalSearch client:only="react" />
        </div>

        <div class="shell__actions">
          <a href="/notifications" class="shell__icon-btn shell__icon-btn--bell" aria-label="Notifiche">
            <Bell size={18} strokeWidth={1.75} />
            <SidebarNotifBadge client:only="react" topbar />
          </a>
          <AppUserMenu client:only="react" />
        </div>
      </header>

      <main class="shell__content">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  /* ─── Reset for the toggle checkbox ──────────────────────────────────── */
  .shell__mobile-toggle {
    display: none;
  }

  /* ─── Grid ───────────────────────────────────────────────────────────── */
  .shell {
    min-block-size: 100dvh;
    display: grid;
    grid-template-columns: 240px 1fr;
    background: var(--color-surface);
  }

  /* ─── Sidebar ────────────────────────────────────────────────────────── */
  .shell__sidebar {
    grid-column: 1;
    position: sticky;
    inset-block-start: 0;
    block-size: 100dvh;
    overflow-y: auto;
    border-inline-end: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding-block: var(--spacing-4);
  }

  .shell__brand {
    padding-inline: var(--spacing-4);
    padding-block-end: var(--spacing-4);
  }
  .shell__brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-3);
    text-decoration: none;
    color: var(--color-text-primary);
  }
  .shell__brand-mark {
    inline-size: 32px;
    block-size: 32px;
    border-radius: var(--radius-md);
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }
  .shell__brand-name {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .shell__nav {
    padding-inline: var(--spacing-3);
    display: grid;
    gap: var(--spacing-5);
    align-content: start;
  }
  .shell__nav-section {
    display: grid;
    gap: var(--spacing-1);
  }
  .shell__nav-label {
    margin: 0;
    padding-inline: var(--spacing-3);
    padding-block-end: var(--spacing-1);
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .shell__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }
  .shell__nav-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    line-height: 1;
    transition: background var(--motion-fast) var(--ease-out-quart),
                color var(--motion-fast) var(--ease-out-quart);
  }
  .shell__nav-item:hover {
    background: var(--color-surface-tinted, color-mix(in oklch, var(--color-mensa-blue) 6%, var(--color-surface)));
    color: var(--color-text-primary);
  }
  .shell__nav-item--active {
    background: color-mix(in oklch, var(--color-mensa-blue) 10%, var(--color-surface));
    color: var(--color-mensa-blue);
    font-weight: 600;
  }

  .shell__sidebar-footer {
    padding: var(--spacing-4);
    border-block-start: 1px solid var(--color-border-subtle);
    margin-block-start: var(--spacing-4);
    color: var(--color-text-tertiary);
  }
  .shell__sidebar-footer p {
    margin: 0;
    font-size: var(--text-2xs);
    line-height: 1.5;
  }

  /* ─── Main + topbar ─────────────────────────────────────────────────── */
  .shell__main {
    grid-column: 2;
    min-inline-size: 0; /* let children shrink */
    display: grid;
    grid-template-rows: 56px 1fr;
  }
  .shell__topbar {
    position: sticky;
    inset-block-start: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding-inline: var(--spacing-6);
    border-block-end: 1px solid var(--color-border-subtle);
    background: color-mix(in oklch, var(--color-surface) 80%, transparent);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
  }
  .shell__hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    padding: var(--spacing-2);
  }
  .shell__hamburger span {
    display: block;
    inline-size: 18px;
    block-size: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
  }
  .shell__page-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    min-inline-size: 0;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  /* Slot for the GlobalSearch React island — the island owns its own
     box/dropdown styling. We only need a flex-grow container so the
     search bar takes the central available width. */
  .shell__search {
    flex: 1;
    display: flex;
    align-items: center;
    min-inline-size: 0;
    margin-inline: auto;
  }
  .shell__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    margin-inline-start: auto;
  }
  .shell__icon-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 36px;
    block-size: 36px;
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .shell__icon-btn:hover {
    background: var(--color-surface-elevated);
    color: var(--color-text-primary);
  }
  .shell__nav-item { position: relative; }

  .shell__content {
    padding-inline: clamp(var(--spacing-4), 4vw, var(--spacing-8));
    padding-block: var(--spacing-6) var(--spacing-10);
    max-inline-size: 1280px;
    inline-size: 100%;
  }

  /* ─── Compact (< 1024px) ─────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .shell {
      grid-template-columns: 1fr;
    }
    .shell__sidebar {
      position: fixed;
      inset-block: 0;
      inset-inline-start: 0;
      inline-size: 280px;
      z-index: 40;
      transform: translateX(-100%);
      transition: transform var(--motion-base) var(--ease-out-quart);
      box-shadow: var(--shadow-modal);
    }
    .shell__mobile-toggle:checked ~ .shell__sidebar {
      transform: translateX(0);
    }
    .shell__main {
      grid-column: 1;
    }
    .shell__hamburger {
      display: flex;
    }
    .shell__search {
      display: none;
    }
  }

  /* Show user-menu first-name label only on wider screens */
  @media (min-width: 768px) {
    :global(.user-menu-name) {
      display: inline !important;
    }
  }
</style>
