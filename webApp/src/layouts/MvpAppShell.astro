---
import BaseLayout from "./BaseLayout.astro";
import {
  Home,
  Compass,
  CalendarDays,
  Users,
  Layers,
  Tag,
  Building2,
  FileText,
  Newspaper,
  Headphones,
  ShoppingBag,
  CreditCard,
  Ticket,
  Receipt,
  Bell,
  CalendarPlus,
  ClipboardList,
  UserCircle,
  HelpCircle,
  ClipboardCheck,
  ShieldCheck,
  FileEdit,
  Mail,
  Wallet,
} from "lucide-react";

interface Props {
  title: string;
  pageTitle?: string;
  audience: "applicant" | "member-full";
  activeHref?: string;
  demoBadge?: string;
}

const {
  title,
  pageTitle,
  audience,
  activeHref,
  demoBadge = "Modalità demo · utente mock: Marco Rossi",
} = Astro.props;

type NavItem = { href: string; label: string; icon: any };
type NavSection = { label: string; items: NavItem[] };

const applicantSections: NavSection[] = [
  {
    label: "Il mio percorso",
    items: [
      { href: "/public/mvp/dashboard",  label: "Dashboard",    icon: Home         },
      { href: "/public/mvp/book-test",  label: "Prenota test", icon: CalendarPlus  },
      { href: "/public/mvp/my-tests",   label: "I miei test",  icon: ClipboardList },
      { href: "/public/mvp/profile",    label: "Profilo",      icon: UserCircle    },
      { href: "/public/mvp/faq",        label: "Aiuto e FAQ",  icon: HelpCircle    },
    ],
  },
];

const memberFullSections: NavSection[] = [
  {
    label: "Comunità",
    items: [
      { href: "/today",      label: "Today",          icon: Home      },
      { href: "/discover",   label: "Esplora",        icon: Compass   },
      { href: "/events",     label: "Eventi",         icon: CalendarDays },
      { href: "/members",    label: "Registro Soci",  icon: Users     },
      { href: "/sigs",       label: "SIG e gruppi",   icon: Layers    },
      { href: "/deals",      label: "Convenzioni",    icon: Tag       },
      { href: "/chapters",   label: "Gruppi locali",  icon: Building2 },
    ],
  },
  {
    label: "Risorse e profilo",
    items: [
      { href: "/documents",     label: "Documenti", icon: FileText  },
      { href: "/quid",          label: "Quid",      icon: Newspaper },
      { href: "/podcasts",      label: "Podcasts",  icon: Headphones },
      { href: "/boutique",      label: "Boutique",  icon: ShoppingBag },
      { href: "/card",          label: "Tessera",   icon: CreditCard },
      { href: "/tickets",       label: "Biglietti", icon: Ticket    },
      { href: "/receipts",      label: "Ricevute",  icon: Receipt   },
      { href: "/notifications", label: "Notifiche", icon: Bell      },
    ],
  },
  {
    label: "Gestione",
    items: [
      { href: "/console/test-assistant/today", label: "Assistente al test", icon: ClipboardCheck },
      { href: "/console/admin/applicants",     label: "Amministrazione",    icon: ShieldCheck    },
      { href: "/console/newsletter",           label: "Newsletter",         icon: Mail           },
      { href: "/admin/blog/keystatic",         label: "Blogging",           icon: FileEdit       },
      { href: "/console/ledger",              label: "Conto economico",    icon: Wallet         },
    ],
  },
];

const sections = audience === "applicant" ? applicantSections : memberFullSections;
---

<BaseLayout title={title}>
  <div class="shell">
    <input type="checkbox" id="mobile-nav-toggle" class="shell__mobile-toggle" />

    <aside class="shell__sidebar" aria-label="Navigazione principale">
      <div class="shell__brand">
        <a href="/public/mvp/hub" class="shell__brand-link">
          <img
            src="/mensa-logo.svg"
            alt=""
            class="shell__brand-mark"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="shell__brand-name">MensaTesting</span>
        </a>
      </div>

      <nav class="shell__nav">
        {
          sections.map((section) => (
            <div
              class="shell__nav-section"
              data-super-only={section.label === "Gestione" ? "" : undefined}
              style={section.label === "Gestione" ? "display: none" : undefined}
            >
              <p class="shell__nav-label">{section.label}</p>
              <ul class="shell__nav-list">
                {section.items.map((item) => {
                  const active = activeHref === item.href || activeHref?.startsWith(item.href + "/");
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`shell__nav-item${active ? " shell__nav-item--active" : ""}`}
                        aria-current={active ? "page" : undefined}
                      >
                        <item.icon size={16} strokeWidth={1.75} aria-hidden="true" />
                        <span>{item.label}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>

      <div class="shell__sidebar-footer">
        <p>the high I.Q. society</p>
        <p>dal 1946</p>
      </div>

      <script is:inline>
        (function () {
          try {
            var raw = localStorage.getItem("mensa.auth.user");
            if (!raw) return;
            var user = JSON.parse(raw);
            var powers = user && user.powers;
            if (!Array.isArray(powers)) return;
            if (powers.indexOf("super") === -1 && powers.indexOf("admin") === -1) return;
            document.querySelectorAll("[data-super-only]").forEach(function (el) {
              el.style.display = "";
            });
          } catch (_) {}
        })();
      </script>
    </aside>

    <div class="shell__main">
      <header class="shell__topbar">
        <label for="mobile-nav-toggle" class="shell__hamburger" aria-label="Apri navigazione">
          <span></span>
          <span></span>
          <span></span>
        </label>

        <div class="shell__page-title" aria-live="polite">
          {pageTitle ?? title}
        </div>

        <div class="shell__search">
          <div class="shell__search-pill" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="8.5" cy="8.5" r="5.5"/>
              <path d="M15 15l-3-3"/>
            </svg>
            <span>Cerca…</span>
          </div>
        </div>

        <div class="shell__actions">
          <div class="shell__user-pill" aria-label="Utente demo: Marco Rossi">
            <span class="shell__user-avatar" aria-hidden="true">MR</span>
            <span class="shell__user-name">Marco Rossi</span>
          </div>
        </div>
      </header>

      <main class="shell__content">
        <div class="demo-banner">
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.345 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/>
          </svg>
          <span>{demoBadge}</span>
          <a href="/public/mvp/hub">← Hub demo</a>
        </div>

        <slot />

        <div class="demo-footer">
          <a href="/">← Esci dalla demo</a>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .shell__mobile-toggle {
    display: none;
  }

  .shell {
    min-block-size: 100dvh;
    display: grid;
    grid-template-columns: 240px 1fr;
    background: var(--color-surface);
  }

  .shell__sidebar {
    grid-column: 1;
    position: sticky;
    inset-block-start: 0;
    block-size: 100dvh;
    overflow-y: auto;
    border-inline-end: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding-block: var(--spacing-4);
  }

  .shell__brand {
    padding-inline: var(--spacing-4);
    padding-block-end: var(--spacing-4);
  }
  .shell__brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-3);
    text-decoration: none;
    color: var(--color-text-primary);
  }
  .shell__brand-mark {
    inline-size: 32px;
    block-size: 32px;
    border-radius: var(--radius-md);
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }
  .shell__brand-name {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .shell__nav {
    padding-inline: var(--spacing-3);
    display: grid;
    gap: var(--spacing-5);
    align-content: start;
  }
  .shell__nav-section {
    display: grid;
    gap: var(--spacing-1);
  }
  .shell__nav-label {
    margin: 0;
    padding-inline: var(--spacing-3);
    padding-block-end: var(--spacing-1);
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .shell__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }
  .shell__nav-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    line-height: 1;
    transition: background var(--motion-fast) var(--ease-out-quart),
                color var(--motion-fast) var(--ease-out-quart);
  }
  .shell__nav-item:hover {
    background: var(--color-surface-tinted, color-mix(in oklch, var(--color-mensa-blue) 6%, var(--color-surface)));
    color: var(--color-text-primary);
  }
  .shell__nav-item--active {
    background: color-mix(in oklch, var(--color-mensa-blue) 10%, var(--color-surface));
    color: var(--color-mensa-blue);
    font-weight: 600;
  }

  .shell__sidebar-footer {
    padding: var(--spacing-4);
    border-block-start: 1px solid var(--color-border-subtle);
    margin-block-start: var(--spacing-4);
    color: var(--color-text-tertiary);
  }
  .shell__sidebar-footer p {
    margin: 0;
    font-size: var(--text-2xs);
    line-height: 1.5;
  }

  .shell__main {
    grid-column: 2;
    min-inline-size: 0;
    display: grid;
    grid-template-rows: 56px 1fr;
  }
  .shell__topbar {
    position: sticky;
    inset-block-start: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding-inline: var(--spacing-6);
    border-block-end: 1px solid var(--color-border-subtle);
    background: color-mix(in oklch, var(--color-surface) 80%, transparent);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
  }
  .shell__hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    padding: var(--spacing-2);
  }
  .shell__hamburger span {
    display: block;
    inline-size: 18px;
    block-size: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
  }
  .shell__page-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    min-inline-size: 0;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  .shell__search {
    flex: 1;
    display: flex;
    align-items: center;
    min-inline-size: 0;
    margin-inline: auto;
  }
  .shell__search-pill {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: 6px var(--spacing-3);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    max-inline-size: 240px;
    inline-size: 100%;
    cursor: default;
  }
  .shell__search-pill svg {
    inline-size: 14px;
    block-size: 14px;
    flex-shrink: 0;
  }
  .shell__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    flex-shrink: 0;
    margin-inline-start: auto;
  }
  .shell__user-pill {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: 4px var(--spacing-2);
    border-radius: var(--radius-full);
    cursor: default;
  }
  .shell__user-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 28px;
    block-size: 28px;
    border-radius: 50%;
    background: var(--color-mensa-blue);
    color: var(--color-text-on-brand);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  .shell__user-name {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .shell__content {
    padding-inline: clamp(var(--spacing-4), 4vw, var(--spacing-8));
    padding-block: var(--spacing-5) var(--spacing-10);
    max-inline-size: 1280px;
    inline-size: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    align-content: start;
    gap: 0;
  }

  .demo-banner {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-3);
    background: color-mix(in oklch, #f59e0b 10%, transparent);
    border: 1px solid color-mix(in oklch, #f59e0b 30%, transparent);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: color-mix(in oklch, #92400e 80%, var(--color-text-primary));
    margin-block-end: var(--spacing-5);
  }
  .demo-banner svg {
    inline-size: 14px;
    block-size: 14px;
    flex-shrink: 0;
    color: #d97706;
  }
  .demo-banner span { flex: 1; }
  .demo-banner a {
    color: inherit;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .demo-banner a:hover { text-decoration: underline; }

  .demo-footer {
    margin-block-start: var(--spacing-8);
    padding-block-start: var(--spacing-4);
    border-block-start: 1px solid var(--color-border-subtle);
    font-size: var(--text-xs);
  }
  .demo-footer a {
    color: var(--color-text-tertiary);
    text-decoration: none;
  }
  .demo-footer a:hover { color: var(--color-text-primary); }

  @media (max-width: 1023px) {
    .shell {
      grid-template-columns: 1fr;
    }
    .shell__sidebar {
      position: fixed;
      inset-block: 0;
      inset-inline-start: 0;
      inline-size: 280px;
      z-index: 40;
      transform: translateX(-100%);
      transition: transform var(--motion-base) var(--ease-out-quart);
      box-shadow: var(--shadow-modal);
    }
    .shell__mobile-toggle:checked ~ .shell__sidebar {
      transform: translateX(0);
    }
    .shell__main {
      grid-column: 1;
    }
    .shell__hamburger {
      display: flex;
    }
    .shell__search {
      display: none;
    }
    .shell__user-name {
      display: none;
    }
  }
</style>
