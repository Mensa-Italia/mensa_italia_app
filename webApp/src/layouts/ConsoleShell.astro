---
import BaseLayout from "./BaseLayout.astro";
import {
  ClipboardCheck,
  UserCheck,
  ClipboardList,
  Upload,
  Users,
  AlertTriangle,
  Banknote,
  CalendarRange,
  UserPlus,
  FileEdit,
  ShieldCheck,
  Mail,
  Newspaper,
  Globe2,
  MapPin,
  Wallet,
  LineChart,
  Link2,
  PlusCircle,
  Download,
} from "lucide-react";

interface Props {
  title: string;
  pageTitle?: string;
  scope: "test-assistant" | "admin" | "blog" | "newsletter" | "ledger";
  activeHref?: string;
  roleBadge?: string;
}

const {
  title,
  pageTitle,
  scope,
  activeHref,
  roleBadge = scope === "admin" ? "Admin nazionale" : scope === "newsletter" ? "Editor newsletter" : scope === "ledger" ? "Tesoreria" : "Assistente sede",
} = Astro.props;

type NavItem = { href: string; label: string; icon: any };
type NavSection = { label: string; items: NavItem[] };

const testAssistantSections: NavSection[] = [
  {
    label: "Assistenza test",
    items: [
      { href: "/console/test-assistant/today",   label: "Test del giorno",   icon: ClipboardCheck },
      { href: "/console/test-assistant/checkin", label: "Check-in",          icon: UserCheck      },
      { href: "/console/test-assistant/score",   label: "Inserimento esito", icon: ClipboardList  },
      { href: "/console/test-assistant/upload",  label: "Upload PDF",        icon: Upload         },
    ],
  },
];

const adminSections: NavSection[] = [
  {
    label: "Aspiranti soci",
    items: [
      { href: "/console/admin/applicants", label: "Aspiranti",        icon: Users         },
      { href: "/console/admin/collisions", label: "Collisioni",       icon: AlertTriangle  },
      { href: "/console/admin/refunds",    label: "Rimborsi",         icon: Banknote       },
      { href: "/console/admin/dates",      label: "Date sessioni",    icon: CalendarRange  },
      { href: "/console/admin/promote",    label: "Promozione socio", icon: UserPlus       },
    ],
  },
  {
    label: "Operatività",
    items: [
      { href: "/console/test-assistant/today", label: "Console assistenti", icon: ClipboardCheck },
    ],
  },
  {
    label: "Contenuti",
    items: [
      { href: "/keystatic", label: "Mensa Blogging", icon: FileEdit },
    ],
  },
];

const blogSections: NavSection[] = [
  {
    label: "Mensa Blogging",
    items: [
      { href: "/keystatic", label: "Apri editor", icon: FileEdit },
    ],
  },
];

const newsletterSections: NavSection[] = [
  {
    label: "Newsletter",
    items: [
      { href: "/console/newsletter",           label: "Tutte le newsletter",    icon: Mail      },
      { href: "/console/newsletter/mensanews", label: "MensaNews",              icon: Newspaper },
      { href: "/console/newsletter/globale",   label: "Newsletter Globale",     icon: Globe2    },
      { href: "/console/newsletter/lombardia", label: "Newsletter Lombardia",   icon: MapPin    },
    ],
  },
];

const ledgerSections: NavSection[] = [
  {
    label: "Gestione conto",
    items: [
      { href: "/console/ledger",          label: "Movimenti",   icon: Wallet    },
      { href: "/console/ledger/insights", label: "Andamento",   icon: LineChart },
    ],
  },
  {
    label: "Operazioni",
    items: [
      { href: "/console/ledger/new-link", label: "Crea link di pagamento", icon: Link2       },
      { href: "/console/ledger/record",   label: "Registra incasso",       icon: PlusCircle  },
      { href: "/console/ledger/export",   label: "Esporta CSV",            icon: Download    },
    ],
  },
];

const sections =
  scope === "test-assistant" ? testAssistantSections
  : scope === "admin" ? adminSections
  : scope === "newsletter" ? newsletterSections
  : scope === "ledger" ? ledgerSections
  : blogSections;
---

<BaseLayout title={title}>
  <div class="console">
    <input type="checkbox" id="console-nav-toggle" class="console__mobile-toggle" />

    <aside class="console__sidebar" aria-label="Navigazione console">
      <div class="console__brand">
        <a href="/today" class="console__back-link">← Torna all'area soci</a>
        <div class="console__brand-row">
          <img
            src="/mensa-logo.svg"
            alt=""
            class="console__brand-mark"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="console__brand-name">Console Mensa</span>
        </div>
      </div>

      <nav class="console__nav">
        {sections.map((section) => (
          <div class="console__nav-section">
            <p class="console__nav-label">{section.label}</p>
            <ul class="console__nav-list">
              {section.items.map((item) => {
                const active = activeHref === item.href || activeHref?.startsWith(item.href + "/");
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`console__nav-item${active ? " console__nav-item--active" : ""}`}
                      aria-current={active ? "page" : undefined}
                    >
                      <item.icon size={16} strokeWidth={1.75} aria-hidden="true" />
                      <span>{item.label}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </nav>

      <div class="console__sidebar-footer">
        <p>the high I.Q. society</p>
        <p>dal 1946</p>
      </div>
    </aside>

    <div class="console__main">
      <header class="console__topbar">
        <label for="console-nav-toggle" class="console__hamburger" aria-label="Apri navigazione">
          <span></span>
          <span></span>
          <span></span>
        </label>

        <div class="console__page-title" aria-live="polite">
          {pageTitle ?? title}
        </div>

        <div class="console__actions">
          <span class="console__role-badge">{roleBadge}</span>
          <div class="console__user-pill" aria-label="Utente demo: Marco Rossi">
            <span class="console__user-avatar" aria-hidden="true">MR</span>
            <span class="console__user-name">Marco Rossi</span>
          </div>
        </div>
      </header>

      <main class="console__content">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .console__mobile-toggle { display: none; }

  .console {
    min-block-size: 100dvh;
    display: grid;
    grid-template-columns: 240px 1fr;
    background: var(--color-surface);
  }

  .console__sidebar {
    grid-column: 1;
    position: sticky;
    inset-block-start: 0;
    block-size: 100dvh;
    overflow-y: auto;
    border-inline-end: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding-block: var(--spacing-4);
  }

  .console__brand {
    padding-inline: var(--spacing-4);
    padding-block-end: var(--spacing-4);
    border-block-end: 1px solid var(--color-border-subtle);
    margin-block-end: var(--spacing-3);
    display: grid;
    gap: var(--spacing-3);
  }
  .console__back-link {
    font-size: var(--text-2xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .console__back-link:hover { color: var(--color-text-primary); }
  .console__brand-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
  }
  .console__brand-mark {
    inline-size: 28px;
    block-size: 28px;
    display: block;
    flex-shrink: 0;
  }
  .console__brand-name {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
  }

  .console__nav {
    padding-inline: var(--spacing-3);
    display: grid;
    gap: var(--spacing-5);
    align-content: start;
  }
  .console__nav-section { display: grid; gap: var(--spacing-1); }
  .console__nav-label {
    margin: 0;
    padding-inline: var(--spacing-3);
    padding-block-end: var(--spacing-1);
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .console__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }
  .console__nav-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    line-height: 1;
    transition: background var(--motion-fast) var(--ease-out-quart),
                color var(--motion-fast) var(--ease-out-quart);
  }
  .console__nav-item:hover {
    background: color-mix(in oklch, var(--color-mensa-blue) 6%, var(--color-surface));
    color: var(--color-text-primary);
  }
  .console__nav-item--active {
    background: color-mix(in oklch, var(--color-mensa-blue) 10%, var(--color-surface));
    color: var(--color-mensa-blue);
    font-weight: 600;
  }

  .console__sidebar-footer {
    padding: var(--spacing-4);
    border-block-start: 1px solid var(--color-border-subtle);
    margin-block-start: var(--spacing-4);
    color: var(--color-text-tertiary);
  }
  .console__sidebar-footer p {
    margin: 0;
    font-size: var(--text-2xs);
    line-height: 1.5;
  }

  .console__main {
    grid-column: 2;
    min-inline-size: 0;
    display: grid;
    grid-template-rows: 56px 1fr;
  }
  .console__topbar {
    position: sticky;
    inset-block-start: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding-inline: var(--spacing-6);
    border-block-end: 1px solid var(--color-border-subtle);
    background: color-mix(in oklch, var(--color-surface) 80%, transparent);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
  }
  .console__hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    padding: var(--spacing-2);
  }
  .console__hamburger span {
    display: block;
    inline-size: 18px;
    block-size: 1.5px;
    background: var(--color-text-primary);
    border-radius: 2px;
  }
  .console__page-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    flex: 1;
    min-inline-size: 0;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  .console__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    flex-shrink: 0;
    margin-inline-start: auto;
  }
  .console__role-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px var(--spacing-3);
    background: color-mix(in oklch, var(--color-mensa-blue) 10%, var(--color-surface));
    color: var(--color-mensa-blue);
    border-radius: var(--radius-full);
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .console__user-pill {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: 4px var(--spacing-2);
    border-radius: var(--radius-full);
    cursor: default;
  }
  .console__user-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 28px;
    block-size: 28px;
    border-radius: 50%;
    background: var(--color-mensa-blue);
    color: var(--color-text-on-brand);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  .console__user-name {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .console__content {
    padding-inline: clamp(var(--spacing-4), 4vw, var(--spacing-8));
    padding-block: var(--spacing-5) var(--spacing-10);
    max-inline-size: 1280px;
    inline-size: 100%;
    display: grid;
    align-content: start;
    gap: 0;
  }

  @media (max-width: 1023px) {
    .console { grid-template-columns: 1fr; }
    .console__sidebar {
      position: fixed;
      inset-block: 0;
      inset-inline-start: 0;
      inline-size: 280px;
      z-index: 40;
      transform: translateX(-100%);
      transition: transform var(--motion-base) var(--ease-out-quart);
      box-shadow: var(--shadow-modal);
    }
    .console__mobile-toggle:checked ~ .console__sidebar {
      transform: translateX(0);
    }
    .console__main { grid-column: 1; }
    .console__hamburger { display: flex; }
    .console__user-name { display: none; }
  }
</style>
