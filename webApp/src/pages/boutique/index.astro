---
import AppShell from "../../layouts/AppShell.astro";
---

<AppShell title="Boutique — Mensa Italia" pageTitle="Boutique">
  <div class="bq">

    <header class="bq-hero">
      <p class="bq-hero__eyebrow">Boutique</p>
      <h1 class="bq-hero__title">Boutique Mensa Italia</h1>
      <p class="bq-hero__sub">Tessera, merchandising, libri e gadget. Spediamo in tutta Italia.</p>
    </header>

    <div class="bq-toolbar">
      <div class="bq-filters" role="list" aria-label="Filtra per categoria">
        <button class="bq-filter bq-filter--active" data-filter="tutto" role="listitem">Tutto</button>
        <button class="bq-filter" data-filter="tessere" role="listitem">Tessere & accessori</button>
        <button class="bq-filter" data-filter="abbigliamento" role="listitem">Abbigliamento</button>
        <button class="bq-filter" data-filter="libri" role="listitem">Libri & rivista</button>
        <button class="bq-filter" data-filter="casa" role="listitem">Casa & ufficio</button>
        <button class="bq-filter" data-filter="limited" role="listitem">Edizione limitata</button>
      </div>

      <div class="bq-toolbar__right">
        <select class="bq-sort" aria-label="Ordina prodotti">
          <option>Più popolari</option>
          <option>Prezzo: crescente</option>
          <option>Prezzo: decrescente</option>
          <option>Novità</option>
        </select>
        <div class="bq-view-toggle">
          <button class="bq-view-btn bq-view-btn--active" data-view="grid" aria-label="Vista griglia" title="Griglia">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
              <rect x="0" y="0" width="7" height="7" rx="1"/><rect x="9" y="0" width="7" height="7" rx="1"/>
              <rect x="0" y="9" width="7" height="7" rx="1"/><rect x="9" y="9" width="7" height="7" rx="1"/>
            </svg>
          </button>
          <button class="bq-view-btn" data-view="list" aria-label="Vista lista" title="Lista">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
              <rect x="0" y="1" width="16" height="2" rx="1"/><rect x="0" y="7" width="16" height="2" rx="1"/>
              <rect x="0" y="13" width="16" height="2" rx="1"/>
            </svg>
          </button>
        </div>
        <a href="/boutique/cart" class="bq-cart-btn" aria-label="Carrello" id="cart-icon-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" width="20" height="20" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="bq-cart-badge" id="cart-count" aria-live="polite">0</span>
        </a>
      </div>
    </div>

    <div class="bq-grid" id="products-grid">

      <a href="/boutique/product/tessera-premium-metallo" class="bq-card" data-cat="tessere">
        <div class="bq-card__img bq-card__img--blue">
          <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
            <rect x="8" y="20" width="64" height="40" rx="6" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
            <circle cx="20" cy="35" r="6" fill="rgba(255,255,255,0.3)"/>
            <rect x="14" y="47" width="36" height="3" rx="1.5" fill="rgba(255,255,255,0.5)"/>
