<style>
  .bq { display: grid; gap: var(--spacing-6); }

  .bq-hero { display: grid; gap: var(--spacing-2); }
  .bq-hero__eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    margin: 0;
  }
  .bq-hero__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.2;
  }
  .bq-hero__sub {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .bq-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-3);
  }
  .bq-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }
  .bq-filter {
    padding: 6px 14px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--motion-fast) var(--ease-out-quart);
  }
  .bq-filter:hover { border-color: var(--color-mensa-blue); color: var(--color-mensa-blue); }
  .bq-filter--active {
    background: var(--color-mensa-blue);
    border-color: var(--color-mensa-blue);
    color: #fff;
  }
  .bq-toolbar__right {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
  }
  .bq-sort {
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    cursor: pointer;
  }
  .bq-view-toggle {
    display: flex;
    gap: 2px;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 3px;
  }
  .bq-view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 26px;
    border-radius: 4px;
    border: none;
    background: transparent;
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: all var(--motion-fast) var(--ease-out-quart);
  }
  .bq-view-btn--active { background: var(--color-mensa-blue); color: #fff; }

