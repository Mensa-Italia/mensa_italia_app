---
import AppShell from "../../layouts/AppShell.astro";
---

<AppShell title="Checkout — Boutique Mensa" pageTitle="Boutique">
  <div class="co">

    <nav class="co-stepper" aria-label="Passi del checkout">
      <ol class="co-stepper__list">
        <li class="co-stepper__item is-current" id="step-ind-1" aria-current="step">
          <span class="co-stepper__num">1</span>
          <span class="co-stepper__label">Spedizione</span>
        </li>
        <li class="co-stepper__item is-future" id="step-ind-2">
          <span class="co-stepper__num">2</span>
          <span class="co-stepper__label">Pagamento</span>
        </li>
        <li class="co-stepper__item is-future" id="step-ind-3">
          <span class="co-stepper__num">3</span>
          <span class="co-stepper__label">Elaborazione</span>
        </li>
      </ol>
    </nav>

    <div class="co-wizard">

      <section class="co-step" id="co-step-1" aria-labelledby="co-step-1-title">
        <h1 class="co-step__title" id="co-step-1-title">Indirizzo di spedizione</h1>
        <form class="co-form" id="shipping-form" onsubmit="event.preventDefault()">
          <div class="co-form__row co-form__row--2">
            <div class="co-form__field">
              <label for="s-nome">Nome</label>
              <input type="text" id="s-nome" placeholder="Marco" autocomplete="given-name" />
            </div>
            <div class="co-form__field">
              <label for="s-cognome">Cognome</label>
              <input type="text" id="s-cognome" placeholder="Rossi" autocomplete="family-name" />
            </div>
          </div>
          <div class="co-form__row co-form__row--3-1">
            <div class="co-form__field">
              <label for="s-via">Via / Piazza</label>
              <input type="text" id="s-via" placeholder="Via Roma" autocomplete="address-line1" />
            </div>
            <div class="co-form__field">
              <label for="s-civico">Civico</label>
              <input type="text" id="s-civico" placeholder="12" autocomplete="address-line2" />
            </div>
          </div>
          <div class="co-form__row co-form__row--2-1-1">
            <div class="co-form__field">
              <label for="s-citta">Città</label>
              <input type="text" id="s-citta" placeholder="Milano" autocomplete="address-level2" />
            </div>
            <div class="co-form__field">
              <label for="s-cap">CAP</label>
              <input type="text" id="s-cap" placeholder="20121" inputmode="numeric" maxlength="5" autocomplete="postal-code" />
            </div>
            <div class="co-form__field">
              <label for="s-prov">Provincia</label>
              <input type="text" id="s-prov" placeholder="MI" maxlength="2" autocomplete="address-level1" />
            </div>
          </div>
          <div class="co-form__field">
            <label for="s-tel">Telefono</label>
            <input type="tel" id="s-tel" placeholder="+39 333 1234567" autocomplete="tel" />
          </div>
          <div class="co-step__actions">
            <a href="/boutique/cart" class="co-btn co-btn--ghost">← Torna al carrello</a>
            <button type="submit" class="co-btn co-btn--primary" id="btn-step1-next">Continua →</button>
          </div>
        </form>
      </section>

      <section class="co-step" id="co-step-2" hidden aria-labelledby="co-step-2-title">
        <h2 class="co-step__title" id="co-step-2-title">Pagamento</h2>
        <div class="co-payment-layout">

          <div class="co-payment-left">
            <div class="co-payment-methods">
              <p class="co-payment-methods__label">Metodo</p>
              <div class="co-payment-radios">
                {[
                  { id: 'pm-card',   label: 'Carta di credito / debito', checked: true },
                  { id: 'pm-apple',  label: 'Apple Pay' },
                  { id: 'pm-google', label: 'Google Pay' },
                  { id: 'pm-paypal', label: 'PayPal' },
                ].map((m) => (
                  <label class="co-radio-label">
                    <input type="radio" name="payment-method" value={m.id} checked={m.checked || undefined} />
                    <span>{m.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <form class="co-form" id="payment-form" onsubmit="event.preventDefault()">
              <div class="co-form__field">
                <label for="c-name">Nome titolare</label>
                <input type="text" id="c-name" placeholder="Marco Rossi" autocomplete="cc-name" />
              </div>
              <div class="co-form__field">
                <label for="c-num">Numero carta</label>
                <input type="text" id="c-num" placeholder="1234 5678 9012 3456" inputmode="numeric" maxlength="19" autocomplete="cc-number" />
              </div>
              <div class="co-form__row co-form__row--2">
                <div class="co-form__field">
                  <label for="c-exp">Scadenza</label>
                  <input type="text" id="c-exp" placeholder="MM / AA" inputmode="numeric" maxlength="7" autocomplete="cc-exp" />
                </div>
                <div class="co-form__field">
                  <label for="c-cvc">CVC</label>
                  <input type="text" id="c-cvc" placeholder="123" inputmode="numeric" maxlength="4" autocomplete="cc-csc" />
                </div>
              </div>
            </form>
          </div>

          <aside class="co-order-summary" id="co-order-summary">
            <h3 class="co-order-summary__title">Riepilogo</h3>
            <div id="co-summary-items" class="co-order-summary__items"></div>
            <div class="co-order-summary__totals" id="co-summary-totals">
              <div class="co-order-summary__row"><span>Subtotale</span><span id="co-sub">—</span></div>
              <div class="co-order-summary__row"><span>Spedizione</span><span id="co-ship">—</span></div>
              <div class="co-order-summary__row co-order-summary__row--total"><span>Totale</span><span id="co-total">—</span></div>
            </div>
          </aside>
        </div>

        <div class="co-step__actions">
          <button class="co-btn co-btn--ghost" id="btn-step2-back">← Indietro</button>
          <button class="co-btn co-btn--primary" id="btn-pay">Paga <span id="pay-amount">€ 0,00</span></button>
        </div>
      </section>

      <section class="co-step" id="co-step-3" hidden aria-labelledby="co-step-3-title" aria-live="polite">
        <h2 class="co-step__title" id="co-step-3-title">Elaborazione pagamento</h2>
        <div class="co-processing" id="co-processing-list"></div>
      </section>

    </div>
  </div>
</AppShell>

<style>
  .co { display: grid; gap: var(--spacing-6); max-width: 800px; }

  .co-stepper { }
  .co-stepper__list {
    list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: 0;
  }
  .co-stepper__item {
    display: flex; align-items: center; gap: var(--spacing-2); flex: 1; position: relative;
  }
  .co-stepper__item:not(:last-child)::after {
    content: ''; flex: 1; height: 1px; background: var(--color-border-subtle); margin: 0 var(--spacing-3);
  }
  .co-stepper__num {
    width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: var(--text-xs); font-weight: 700; flex-shrink: 0;
    background: var(--color-border-subtle); color: var(--color-text-tertiary);
    transition: all var(--motion-fast) var(--ease-out-quart);
  }
  .co-stepper__label { font-size: var(--text-xs); font-weight: 500; color: var(--color-text-tertiary); white-space: nowrap; }
  .co-stepper__item.is-current .co-stepper__num { background: var(--color-mensa-blue); color: #fff; }
  .co-stepper__item.is-current .co-stepper__label { color: var(--color-text-primary); font-weight: 600; }
  .co-stepper__item.is-done .co-stepper__num { background: #22c55e; color: #fff; }
  .co-stepper__item.is-done .co-stepper__label { color: var(--color-text-secondary); }

  .co-step__title { margin: 0 0 var(--spacing-5) 0; font-size: 1.3rem; font-weight: 700; color: var(--color-text-primary); }
  .co-form { display: grid; gap: var(--spacing-4); }
  .co-form__field { display: grid; gap: 6px; }
  .co-form__field label { font-size: var(--text-xs); font-weight: 600; color: var(--color-text-secondary); }
  .co-form__field input {
    padding: 10px 14px; border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-border-subtle); background: var(--color-surface-elevated);
    font-size: var(--text-xs); color: var(--color-text-primary);
    transition: border-color var(--motion-fast) var(--ease-out-quart);
  }
  .co-form__field input:focus { outline: none; border-color: var(--color-mensa-blue); }

  .co-form__row { display: grid; gap: var(--spacing-3); }
  .co-form__row--2 { grid-template-columns: 1fr 1fr; }
  .co-form__row--3-1 { grid-template-columns: 3fr 1fr; }
  .co-form__row--2-1-1 { grid-template-columns: 2fr 1fr 1fr; }
  @media (max-width: 600px) {
    .co-form__row--2,
    .co-form__row--3-1,
    .co-form__row--2-1-1 { grid-template-columns: 1fr; }
  }

  .co-step__actions {
    display: flex; justify-content: flex-end; gap: var(--spacing-3);
    margin-top: var(--spacing-6); padding-top: var(--spacing-4);
    border-top: 1px solid var(--color-border-subtle); flex-wrap: wrap;
  }
  .co-btn {
    padding: 11px 24px; border-radius: var(--radius-md);
    font-size: var(--text-sm); font-weight: 600; cursor: pointer;
    transition: all var(--motion-fast) var(--ease-out-quart); border: 2px solid transparent;
  }
  .co-btn--primary { background: var(--color-mensa-blue); color: #fff; border-color: var(--color-mensa-blue); }
  .co-btn--primary:hover { opacity: 0.88; }
  .co-btn--ghost {
    background: transparent; color: var(--color-mensa-blue); border-color: var(--color-mensa-blue);
    text-decoration: none; display: inline-flex; align-items: center;
  }
  .co-btn--ghost:hover { background: color-mix(in oklch, var(--color-mensa-blue) 8%, var(--color-surface)); }

  .co-payment-layout { display: grid; grid-template-columns: 1fr 280px; gap: var(--spacing-6); align-items: start; }
  @media (max-width: 720px) { .co-payment-layout { grid-template-columns: 1fr; } }

  .co-payment-methods { margin-bottom: var(--spacing-4); }
  .co-payment-methods__label { margin: 0 0 var(--spacing-2) 0; font-size: var(--text-xs); font-weight: 600; color: var(--color-text-secondary); }
  .co-payment-radios { display: grid; gap: var(--spacing-2); }
  .co-radio-label {
    display: flex; align-items: center; gap: var(--spacing-2);
    font-size: var(--text-xs); color: var(--color-text-primary); cursor: pointer;
  }

  .co-order-summary {
    background: var(--color-surface-elevated); border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg); padding: var(--spacing-4); display: grid; gap: var(--spacing-3);
    position: sticky; top: 72px;
  }
  .co-order-summary__title { margin: 0; font-size: var(--text-xs); font-weight: 700; color: var(--color-text-primary); }
  .co-order-summary__items { display: grid; gap: var(--spacing-2); }
  .co-order-summary__item {
    display: flex; justify-content: space-between; gap: var(--spacing-2);
    font-size: var(--text-2xs); color: var(--color-text-secondary);
  }
  .co-order-summary__item-name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .co-order-summary__totals { display: grid; gap: var(--spacing-2); border-top: 1px solid var(--color-border-subtle); padding-top: var(--spacing-3); }
  .co-order-summary__row {
    display: flex; justify-content: space-between;
    font-size: var(--text-2xs); color: var(--color-text-secondary); font-variant-numeric: tabular-nums;
  }
  .co-order-summary__row--total { font-size: var(--text-xs); font-weight: 700; color: var(--color-text-primary); }

  .co-processing {
    display: grid; gap: var(--spacing-4); padding: var(--spacing-6) 0; max-width: 400px;
  }
  .co-processing-row {
    display: flex; align-items: center; gap: var(--spacing-3);
    font-size: var(--text-sm); color: var(--color-text-tertiary);
  }
  .co-processing-row.is-done { color: var(--color-text-primary); }
  .co-processing-row.is-active { color: var(--color-mensa-blue); font-weight: 600; }
  .co-processing-icon {
    width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; background: var(--color-border-subtle); font-size: 12px;
  }
  .co-processing-row.is-done   .co-processing-icon { background: #22c55e; color: #fff; }
  .co-processing-row.is-active .co-processing-icon { background: var(--color-mensa-blue); color: #fff; }
  .co-spinner {
    width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.4);
    border-top-color: #fff; border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script is:inline>
  (function () {
    var CART_KEY = 'mensa_boutique_cart';

    function getCart() { try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch (_) { return []; } }
    function fmt(n) { return '€ ' + n.toFixed(2).replace('.', ','); }

    function calcTotals() {
      var cart = getCart();
      var sub = cart.reduce(function (s, i) { return s + i.price * (i.qty || 1); }, 0);
      var ship = (cart.length === 0 || sub >= 60) ? 0 : 4.90;
      return { sub: sub, ship: ship, total: sub + ship, cart: cart };
    }

    function fillSummary() {
      var t = calcTotals();
      var itemsEl = document.getElementById('co-summary-items');
      if (itemsEl) {
        itemsEl.innerHTML = '';
        t.cart.forEach(function (item) {
          var d = document.createElement('div');
          d.className = 'co-order-summary__item';
          d.innerHTML = '<span class="co-order-summary__item-name">' + item.name + ' ×' + (item.qty||1) + '</span>'
            + '<span>' + fmt(item.price * (item.qty||1)) + '</span>';
          itemsEl.appendChild(d);
        });
      }
      var subEl = document.getElementById('co-sub');
      var shipEl = document.getElementById('co-ship');
      var totalEl = document.getElementById('co-total');
      var payEl = document.getElementById('pay-amount');
      if (subEl) subEl.textContent = fmt(t.sub);
      if (shipEl) shipEl.textContent = t.ship === 0 ? 'Gratuita' : fmt(t.ship);
      if (totalEl) totalEl.textContent = fmt(t.total);
      if (payEl) payEl.textContent = fmt(t.total);
    }
    fillSummary();

    function goToStep(n) {
      [1,2,3].forEach(function (i) {
        var step = document.getElementById('co-step-' + i);
        var ind  = document.getElementById('step-ind-' + i);
        if (!step || !ind) return;
        if (i === n) {
          step.hidden = false;
          ind.className = 'co-stepper__item is-current';
          ind.setAttribute('aria-current', 'step');
        } else if (i < n) {
          step.hidden = true;
          ind.className = 'co-stepper__item is-done';
          ind.removeAttribute('aria-current');
          ind.querySelector('.co-stepper__num').textContent = '✓';
        } else {
          step.hidden = true;
          ind.className = 'co-stepper__item is-future';
          ind.removeAttribute('aria-current');
        }
      });
    }

    document.getElementById('btn-step1-next').addEventListener('click', function () {
      fillSummary();
      goToStep(2);
    });
    document.getElementById('btn-step2-back').addEventListener('click', function () { goToStep(1); });

    document.getElementById('btn-pay').addEventListener('click', function () {
      goToStep(3);
      runProcessing();
    });

    function runProcessing() {
      var steps = [
        'Verifica carta',
        'Autorizzazione',
        'Conferma pagamento',
        'Generazione ricevuta',
      ];
      var listEl = document.getElementById('co-processing-list');
      listEl.innerHTML = '';
      var rows = steps.map(function (label) {
        var row = document.createElement('div');
        row.className = 'co-processing-row';
        row.innerHTML = '<span class="co-processing-icon"><span class="co-spinner"></span></span>'
          + '<span>' + label + '</span>';
        row.style.opacity = '0.3';
        listEl.appendChild(row);
        return row;
      });

      var idx = 0;
      function next() {
        if (idx >= rows.length) {
          setTimeout(function () {
            window.location.href = '/boutique/order-confirmed?ref=BQ-2026-0042';
          }, 600);
          return;
        }
        var row = rows[idx];
        row.style.opacity = '1';
        row.className = 'co-processing-row is-active';
        setTimeout(function () {
          row.className = 'co-processing-row is-done';
          row.querySelector('.co-processing-icon').textContent = '✓';
          idx++;
          setTimeout(next, 300);
        }, 900);
      }
      setTimeout(next, 300);
    }
  })();
</script>
