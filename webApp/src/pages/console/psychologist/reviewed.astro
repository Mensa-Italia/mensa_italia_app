---
import ConsoleShell from "../../../layouts/ConsoleShell.astro";

const tests = [
  { dataVal: "18/05/2026", aspirante: "Davide Caruso",     sede: "Napoli",  punteggio: 28, esito: "Non passato", note: "Soglia non raggiunta",            file: "davide_caruso_test_18mag.pdf"    },
  { dataVal: "17/05/2026", aspirante: "Sara De Rosa",      sede: "Bologna", punteggio: 38, esito: "Passato",     note: "Velocità sopra la media",         file: "sara_derosa_test_17mag.pdf"      },
  { dataVal: "15/05/2026", aspirante: "Matteo Colombo",    sede: "Milano",  punteggio: 36, esito: "Passato",     note: "Risposte coerenti",               file: "matteo_colombo_test_15mag.pdf"   },
  { dataVal: "14/05/2026", aspirante: "Chiara Ricci",      sede: "Roma",    punteggio: 31, esito: "Non passato", note: "Difficoltà con sequenze spaziali", file: "chiara_ricci_test_14mag.pdf"     },
  { dataVal: "12/05/2026", aspirante: "Alberto Fontana",   sede: "Firenze", punteggio: 40, esito: "Passato",     note: "Punteggio eccellente",            file: "alberto_fontana_test_12mag.pdf"  },
  { dataVal: "11/05/2026", aspirante: "Elena Moretti",     sede: "Torino",  punteggio: 37, esito: "Passato",     note: "Buona gestione del tempo",        file: "elena_moretti_test_11mag.pdf"    },
  { dataVal: "10/05/2026", aspirante: "Francesca Lombardi",sede: "Torino",  punteggio: 26, esito: "Non passato", note: "Test interrotto al 70%",          file: "francesca_lombardi_test_10mag.pdf"},
  { dataVal: "08/05/2026", aspirante: "Roberto Vitale",    sede: "Roma",    punteggio: 39, esito: "Passato",     note: "Ottima concentrazione",           file: "roberto_vitale_test_08mag.pdf"   },
  { dataVal: "06/05/2026", aspirante: "Alessia Bruno",     sede: "Milano",  punteggio: 34, esito: "Passato",     note: "Risposte coerenti",               file: "alessia_bruno_test_06mag.pdf"    },
  { dataVal: "05/05/2026", aspirante: "Gianluca Serra",    sede: "Bologna", punteggio: 29, esito: "Non passato", note: "Errori sistematici su analogie",  file: "gianluca_serra_test_05mag.pdf"   },
  { dataVal: "03/05/2026", aspirante: "Monica Riva",       sede: "Napoli",  punteggio: 41, esito: "Passato",     note: "Punteggio nella fascia alta",     file: "monica_riva_test_03mag.pdf"      },
  { dataVal: "01/05/2026", aspirante: "Luca Gentile",      sede: "Firenze", punteggio: 35, esito: "Passato",     note: "Performance costante",            file: "luca_gentile_test_01mag.pdf"     },
];
---

<ConsoleShell
  title="Console test · Test valutati"
  pageTitle="Test valutati"
  scope="test"
  activeHref="/console/psychologist/reviewed"
>
  <div class="page-content">

    <header class="page-header">
      <div>
        <h1 class="page-header__title">Test valutati</h1>
        <p class="page-header__sub">Storico completo delle tue valutazioni.</p>
      </div>
      <span class="counter-pill">47 test valutati negli ultimi 90 giorni · 52% passati</span>
    </header>

    <div class="toolbar">
      <select class="toolbar__select" aria-label="Filtra per esito">
        <option>Tutti</option>
        <option>Passato</option>
        <option>Non passato</option>
      </select>
      <select class="toolbar__select" aria-label="Filtra per data">
        <option>Ultimi 90 giorni</option>
        <option>Ultimi 30 giorni</option>
        <option>Ultimi 7 giorni</option>
      </select>
    </div>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Data valutazione</th>
            <th>Aspirante</th>
            <th>Sede</th>
            <th>Punteggio</th>
            <th>Esito</th>
            <th>Note</th>
            <th>Documento</th>
          </tr>
        </thead>
        <tbody>
          {tests.map((t) => (
            <tr>
              <td class="td--date">{t.dataVal}</td>
              <td class="td--name">{t.aspirante}</td>
              <td>{t.sede}</td>
              <td class="td--score">{t.punteggio}<span class="td--score-max">/45</span></td>
              <td>
                <span class={`badge ${t.esito === "Passato" ? "badge--green" : "badge--red"}`}>{t.esito}</span>
              </td>
              <td class="td--note">{t.note}</td>
              <td><a href="#" class="file-link">{t.file}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</ConsoleShell>

<style>
  .page-content { display: grid; gap: var(--spacing-5); }

  .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--spacing-4); flex-wrap: wrap; }
  .page-header__title { margin: 0; font-size: clamp(var(--text-xl), 3vw, var(--text-2xl)); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text-primary); }
  .page-header__sub { margin: 0; font-size: var(--text-sm); color: var(--color-text-secondary); }

  .counter-pill { display: inline-flex; align-items: center; padding: 0.35rem 0.875rem; background: color-mix(in oklch, var(--color-mensa-blue) 8%, var(--color-surface)); border: 1px solid color-mix(in oklch, var(--color-mensa-blue) 20%, transparent); border-radius: 9999px; font-size: var(--text-xs); font-weight: 600; color: var(--color-mensa-blue); white-space: nowrap; flex-shrink: 0; align-self: flex-start; }

  .toolbar { display: flex; gap: var(--spacing-3); flex-wrap: wrap; align-items: center; }
  .toolbar__select { padding: 0.45rem 0.75rem; border: 1px solid var(--color-border-subtle); border-radius: var(--radius-sm); font-size: var(--text-sm); background: var(--color-surface); color: var(--color-text-primary); }

  .table-wrap { background: var(--color-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); overflow-x: auto; }
  .table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .table thead tr { background: var(--color-surface-elevated); border-block-end: 1px solid var(--color-border-subtle); }
  .table th { padding: 0.75rem 0.875rem; text-align: left; font-size: var(--text-2xs); font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-tertiary); white-space: nowrap; }
  .table tbody tr { border-block-end: 1px solid var(--color-border-subtle); transition: background var(--motion-fast) var(--ease-out-quart); }
  .table tbody tr:last-child { border-block-end: none; }
  .table tbody tr:hover { background: var(--color-surface-elevated); }
  .table td { padding: 0.75rem 0.875rem; color: var(--color-text-primary); vertical-align: middle; }
  .td--name { font-weight: 600; white-space: nowrap; }
  .td--date { color: var(--color-text-tertiary); font-size: var(--text-xs); white-space: nowrap; }
  .td--score { font-weight: 700; }
  .td--score-max { font-weight: 400; color: var(--color-text-tertiary); font-size: var(--text-xs); }
  .td--note { font-size: var(--text-xs); color: var(--color-text-secondary); max-inline-size: 220px; }

  .badge { display: inline-block; padding: 0.2rem 0.55rem; border-radius: 9999px; font-size: var(--text-2xs); font-weight: 700; letter-spacing: 0.02em; white-space: nowrap; }
  .badge--green { background: #d1fae5; color: #065f46; }
  .badge--red   { background: #fee2e2; color: #991b1b; }

  .file-link { color: var(--color-mensa-blue); text-decoration: none; font-size: var(--text-xs); font-weight: 500; }
  .file-link:hover { text-decoration: underline; }

  @media (max-width: 700px) {
    .table thead { display: none; }
    .table tbody, .table tr, .table td { display: block; width: 100%; }
    .table tr { padding: 0.75rem 1rem; border-block-end: 1px solid var(--color-border-subtle); }
    .table td { padding: 0.2rem 0; }
  }
</style>
