---
import ConsoleShell from "../../../layouts/ConsoleShell.astro";
---

<ConsoleShell
  scope="ledger"
  activeHref="/console/ledger/new-link"
  pageTitle="Crea link di pagamento"
  title="Mensa Ledger · Nuovo link"
>
  <div class="page">

    <header class="page-header">
      <div>
        <h1 class="page-header__title">Crea link di pagamento</h1>
        <p class="page-header__sub">Genera un link sicuro da condividere con un socio o aspirante socio.</p>
      </div>
    </header>

    <div id="form-section">
      <form class="form-card" id="link-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="link-title">Titolo</label>
          <input type="text" id="link-title" class="form-input" placeholder="es. Quota socio 2026" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="link-desc">Descrizione <span class="form-label--optional">(opzionale)</span></label>
          <textarea id="link-desc" class="form-input form-textarea" placeholder="Dettagli aggiuntivi per il pagante…" rows="3"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group form-group--amount">
            <label class="form-label" for="link-amount">Importo</label>
            <div class="input-prefix-wrap">
              <span class="input-prefix">€</span>
              <input type="number" id="link-amount" class="form-input input--prefixed" placeholder="50,00" min="0.01" step="0.01" required />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="link-causale">Causale</label>
            <select id="link-causale" class="form-input">
              <option>Quote soci</option>
              <option>Test ammissione</option>
              <option>Evento</option>
              <option>Donazione</option>
              <option>Altro</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="link-expiry">Scadenza link</label>
          <input type="date" id="link-expiry" class="form-input" value="2026-06-17" />
        </div>
        <fieldset class="form-fieldset">
          <legend class="form-label">Destinatario <span class="form-label--optional">(opzionale)</span></legend>
          <div class="form-row">
            <input type="text" class="form-input" placeholder="Nome" aria-label="Nome destinatario" />
            <input type="email" class="form-input" placeholder="email@esempio.it" aria-label="Email destinatario" />
          </div>
        </fieldset>
        <div class="form-group">
          <p class="form-label">Metodi accettati</p>
          <div class="chips-row" role="group" aria-label="Metodi di pagamento">
            <label class="method-chip method-chip--active"><input type="checkbox" checked class="sr-only" /> Carta</label>
            <label class="method-chip method-chip--active"><input type="checkbox" checked class="sr-only" /> Bonifico SEPA</label>
            <label class="method-chip method-chip--active"><input type="checkbox" checked class="sr-only" /> Apple Pay</label>
            <label class="method-chip method-chip--active"><input type="checkbox" checked class="sr-only" /> Google Pay</label>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn--primary" id="generate-btn">Genera link</button>
          <a href="/console/ledger" class="btn btn--ghost">Annulla</a>
        </div>
      </form>
    </div>

    <div id="success-section" class="success-card" hidden>
      <div class="success-icon" aria-hidden="true">✓</div>
      <h2 class="success-title">Link creato</h2>
      <p class="success-sub">Condividilo o invialo via email — resta valido fino al 17/06/2026.</p>
      <div class="link-row">
        <input type="text" id="link-url" class="form-input link-url-input" readonly value="https://pay.mensa.it/q/MN-LINK-2026-0193" aria-label="URL link di pagamento" />
        <button type="button" class="btn btn--primary" id="copy-btn" onclick="copyLink()">Copia</button>
      </div>
      <div class="success-actions">
        <button type="button" class="btn btn--primary" onclick="toggleEmailPanel()">Invia via email</button>
        <button type="button" class="btn btn--ghost" onclick="toggleQr()">Mostra QR</button>
        <a href="/console/ledger" class="action-link">Vai ai movimenti →</a>
      </div>
      <div id="email-panel" class="email-panel" hidden>
        <input type="email" class="form-input" placeholder="email@esempio.it" aria-label="Indirizzo email destinatario" />
        <label class="checkbox-label">
          <input type="checkbox" /> Aggiungi messaggio personale
        </label>
        <button type="button" class="btn btn--primary">Invia ora</button>
      </div>
      <div id="qr-panel" hidden>
        <svg viewBox="0 0 120 120" class="qr-svg" role="img" aria-label="QR code placeholder">
          <rect width="120" height="120" fill="white"/>
          <rect x="10" y="10" width="30" height="30" fill="none" stroke="#111" stroke-width="4"/>
          <rect x="15" y="15" width="18" height="18" fill="#111"/>
          <rect x="80" y="10" width="30" height="30" fill="none" stroke="#111" stroke-width="4"/>
          <rect x="85" y="15" width="18" height="18" fill="#111"/>
          <rect x="10" y="80" width="30" height="30" fill="none" stroke="#111" stroke-width="4"/>
          <rect x="15" y="85" width="18" height="18" fill="#111"/>
          <rect x="50" y="10" width="6" height="6" fill="#111"/>
          <rect x="58" y="10" width="6" height="6" fill="#111"/>
          <rect x="50" y="18" width="6" height="6" fill="#111"/>
          <rect x="58" y="26" width="6" height="6" fill="#111"/>
          <rect x="50" y="34" width="6" height="6" fill="#111"/>
          <rect x="50" y="50" width="6" height="6" fill="#111"/>
          <rect x="58" y="50" width="6" height="6" fill="#111"/>
          <rect x="66" y="50" width="6" height="6" fill="#111"/>
          <rect x="74" y="50" width="6" height="6" fill="#111"/>
          <rect x="82" y="50" width="6" height="6" fill="#111"/>
          <rect x="50" y="58" width="6" height="6" fill="#111"/>
          <rect x="66" y="58" width="6" height="6" fill="#111"/>
          <rect x="82" y="58" width="6" height="6" fill="#111"/>
          <rect x="50" y="66" width="6" height="6" fill="#111"/>
          <rect x="58" y="66" width="6" height="6" fill="#111"/>
          <rect x="74" y="66" width="6" height="6" fill="#111"/>
          <rect x="82" y="66" width="6" height="6" fill="#111"/>
          <rect x="50" y="74" width="6" height="6" fill="#111"/>
          <rect x="66" y="74" width="6" height="6" fill="#111"/>
          <rect x="50" y="82" width="6" height="6" fill="#111"/>
          <rect x="58" y="82" width="6" height="6" fill="#111"/>
          <rect x="66" y="82" width="6" height="6" fill="#111"/>
          <rect x="74" y="82" width="6" height="6" fill="#111"/>
          <rect x="82" y="82" width="6" height="6" fill="#111"/>
          <rect x="50" y="90" width="6" height="6" fill="#111"/>
          <rect x="66" y="90" width="6" height="6" fill="#111"/>
          <rect x="82" y="90" width="6" height="6" fill="#111"/>
          <rect x="82" y="98" width="6" height="6" fill="#111"/>
          <rect x="82" y="106" width="6" height="6" fill="#111"/>
        </svg>
      </div>
    </div>

  </div>
</ConsoleShell>

<script is:inline>
  document.getElementById('link-form').addEventListener('submit', function(e) {
    e.preventDefault();
    document.getElementById('form-section').hidden = true;
    document.getElementById('success-section').hidden = false;
  });

  function copyLink() {
    const url = document.getElementById('link-url').value;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(url);
    }
    const btn = document.getElementById('copy-btn');
    const orig = btn.textContent;
    btn.textContent = 'Copiato ✓';
    setTimeout(function() { btn.textContent = orig; }, 1500);
  }

  function toggleEmailPanel() {
    const panel = document.getElementById('email-panel');
    panel.hidden = !panel.hidden;
  }

  function toggleQr() {
    const panel = document.getElementById('qr-panel');
    panel.hidden = !panel.hidden;
  }

  document.querySelectorAll('.method-chip').forEach(function(chip) {
    chip.addEventListener('click', function() {
      chip.classList.toggle('method-chip--active');
    });
  });
</script>

<style>
  .page { display: grid; gap: var(--spacing-5); }

  .page-header__title { margin: 0; font-size: clamp(var(--text-xl), 3vw, var(--text-2xl)); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text-primary); }
  .page-header__sub { margin: 0.25rem 0 0; font-size: var(--text-sm); color: var(--color-text-secondary); }

  .form-card {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--spacing-6);
    max-inline-size: 640px;
    display: grid;
    gap: var(--spacing-4);
  }
  .form-group { display: grid; gap: var(--spacing-1); }
  .form-label { font-size: var(--text-sm); font-weight: 600; color: var(--color-text-primary); }
  .form-label--optional { font-weight: 400; color: var(--color-text-tertiary); }
  .form-input {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    background: var(--color-surface);
    color: var(--color-text-primary);
    width: 100%;
    box-sizing: border-box;
  }
  .form-input:focus { outline: 2px solid var(--color-mensa-blue); outline-offset: 1px; border-color: var(--color-mensa-blue); }
  .form-textarea { resize: vertical; font-family: inherit; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-3); }
  .form-fieldset { border: none; padding: 0; margin: 0; display: grid; gap: var(--spacing-2); }
  .input-prefix-wrap { display: flex; align-items: stretch; }
  .input-prefix { display: inline-flex; align-items: center; padding: 0 0.75rem; background: var(--color-surface-elevated); border: 1px solid var(--color-border-subtle); border-inline-end: none; border-radius: var(--radius-sm) 0 0 var(--radius-sm); font-size: var(--text-sm); color: var(--color-text-secondary); font-weight: 600; white-space: nowrap; }
  .input--prefixed { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }

  .chips-row { display: flex; gap: var(--spacing-2); flex-wrap: wrap; }
  .method-chip {
    display: inline-flex; align-items: center; padding: 0.35rem 0.85rem;
    border: 1.5px solid var(--color-border-subtle); border-radius: 9999px;
    font-size: var(--text-xs); font-weight: 600; color: var(--color-text-secondary);
    cursor: pointer; transition: all 0.15s; background: var(--color-surface);
  }
  .method-chip--active {
    background: color-mix(in oklch, var(--color-mensa-blue) 10%, var(--color-surface));
    border-color: var(--color-mensa-blue); color: var(--color-mensa-blue);
  }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }

  .form-actions { display: flex; gap: var(--spacing-3); padding-block-start: var(--spacing-2); }

  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 0.5rem 1.25rem; border-radius: var(--radius-sm); font-size: var(--text-sm); font-weight: 700; text-decoration: none; cursor: pointer; border: 2px solid transparent; transition: opacity 0.15s; white-space: nowrap; }
  .btn:hover { opacity: 0.85; }
  .btn--primary { background: var(--color-mensa-blue); color: var(--color-text-on-brand); }
  .btn--ghost { background: transparent; border-color: var(--color-border-subtle); color: var(--color-text-primary); }

  .success-card {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--spacing-6);
    max-inline-size: 640px;
    display: grid;
    gap: var(--spacing-4);
  }
  .success-icon { width: 48px; height: 48px; border-radius: 50%; background: #d1fae5; color: #065f46; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 700; }
  .success-title { margin: 0; font-size: var(--text-xl); font-weight: 700; color: var(--color-text-primary); }
  .success-sub { margin: 0; font-size: var(--text-sm); color: var(--color-text-secondary); }
  .link-row { display: flex; gap: var(--spacing-2); }
  .link-url-input { font-family: monospace; font-size: var(--text-xs); }
  .success-actions { display: flex; gap: var(--spacing-3); align-items: center; flex-wrap: wrap; }
  .action-link { font-size: var(--text-sm); font-weight: 600; color: var(--color-mensa-blue); text-decoration: none; }
  .action-link:hover { text-decoration: underline; }

  .email-panel { display: grid; gap: var(--spacing-3); padding: var(--spacing-4); background: var(--color-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-sm); }
  .checkbox-label { display: flex; align-items: center; gap: var(--spacing-2); font-size: var(--text-sm); color: var(--color-text-secondary); cursor: pointer; }

  .qr-svg { width: 160px; height: 160px; display: block; border: 1px solid var(--color-border-subtle); border-radius: var(--radius-sm); padding: var(--spacing-2); background: white; }

  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .form-card, .success-card { padding: var(--spacing-4); }
    .form-actions, .success-actions { flex-direction: column; }
    .link-row { flex-direction: column; }
  }
</style>
