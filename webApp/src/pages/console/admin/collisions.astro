---
import ConsoleShell from "../../../layouts/ConsoleShell.astro";

const collisions = [
  {
    id: "col1",
    field: "Codice fiscale",
    aspName: "Marco Rossi",
    aspEmail: "marco.rossi@email.it",
    aspCf: "RSSMRC85A01H501Z",
    socName: "Marco Rossi",
    socEmail: "m.rossi@lavoro.it",
    socCf: "RSSMRC85A01H501Z",
    conflict: "CF identico",
  },
  {
    id: "col2",
    field: "Email",
    aspName: "Elena Moretti",
    aspEmail: "e.moretti@mail.it",
    aspCf: "MRTLNE89A52H501X",
    socName: "Elena Maria Moretti",
    socEmail: "e.moretti@mail.it",
    socCf: "MRTMLN87A52H501Z",
    conflict: "Email identica",
  },
  {
    id: "col3",
    field: "Codice fiscale",
    aspName: "Federico Marini",
    aspEmail: "fedmarini@email.it",
    aspCf: "MRNFRC90F12H501W",
    socName: "Federico Marini",
    socEmail: "fmarini.socio@mensaitalia.it",
    socCf: "MRNFRC90F12H501W",
    conflict: "CF identico",
  },
];
---

<ConsoleShell
  title="Collisioni CF/email — Admin Nazionale"
  pageTitle="Collisioni CF / email"
  
  activeHref="/console/admin/collisions" scope="test"
  
>
  <div class="page-content">

    <header class="page-header">
      <div>
        <h1 class="page-header__title">Collisioni CF / email</h1>
        <p class="page-header__sub">3 collisioni in sospeso · richiedono revisione manuale</p>
      </div>
      <span class="badge badge--red">3 in sospeso</span>
    </header>

    <a href="/console/admin/applicants" class="back-link">← Torna alla lista aspiranti</a>

    <div class="info-banner">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd"/></svg>
      <p>Una collisione indica che il CF o l'email dell'aspirante corrisponde a un socio già registrato. Verificare manualmente se si tratta della stessa persona o di un omonimo.</p>
    </div>

    <div class="collision-list">
      {collisions.map((c) => (
        <div class="collision-card">
          <div class="collision-card__header">
            <span class="conflict-badge">
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.345 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>
              {c.conflict}
            </span>
          </div>
          <div class="collision-card__comparison">
            <div class="person-col">
              <p class="person-col__role">Aspirante</p>
              <p class="person-col__name">{c.aspName}</p>
              <p class="person-col__detail">{c.aspEmail}</p>
              <p class={`person-col__detail ${c.field === "Codice fiscale" ? "highlight" : ""}`}>{c.aspCf}</p>
            </div>
            <div class="vs-sep" aria-hidden="true">VS</div>
            <div class="person-col">
              <p class="person-col__role">Socio esistente</p>
              <p class="person-col__name">{c.socName}</p>
              <p class={`person-col__detail ${c.field === "Email" ? "highlight" : ""}`}>{c.socEmail}</p>
              <p class={`person-col__detail ${c.field === "Codice fiscale" ? "highlight" : ""}`}>{c.socCf}</p>
            </div>
          </div>
          <div class="collision-card__actions">
            <a href="/console/admin/applicants" class="btn btn--primary btn--sm">È la stessa persona — collega</a>
            <a href="/console/admin/applicants" class="btn btn--danger btn--sm">Rifiuta registrazione aspirante</a>
          </div>
        </div>
      ))}
    </div>

  </div>
</ConsoleShell>

<style>
  .page-content { max-inline-size: 1000px; display: grid; gap: var(--spacing-5); }

  .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--spacing-4); flex-wrap: wrap; }
  .page-header__title { margin: 0; font-size: clamp(var(--text-xl), 3vw, var(--text-2xl)); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text-primary); }
  .page-header__sub { margin: 0; font-size: var(--text-sm); color: var(--color-text-secondary); }

  .badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 9999px; font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.04em; white-space: nowrap; flex-shrink: 0; align-self: flex-start; }
  .badge--red { background: #fee2e2; color: #991b1b; }

  .back-link { font-size: var(--text-xs); color: var(--color-mensa-blue); text-decoration: none; font-weight: 500; width: fit-content; }
  .back-link:hover { text-decoration: underline; }

  .info-banner { display: flex; gap: var(--spacing-3); align-items: flex-start; padding: var(--spacing-3) var(--spacing-4); background: #eff6ff; border: 1px solid #93c5fd; border-radius: var(--radius-md); font-size: var(--text-sm); color: #1e3a8a; line-height: 1.5; }
  .info-banner svg { width: 1.25rem; height: 1.25rem; flex-shrink: 0; margin-block-start: 0.1rem; }
  .info-banner p { margin: 0; }

  .collision-list { display: grid; gap: var(--spacing-4); }
  .collision-card { background: var(--color-surface); border: 1px solid #fca5a5; border-radius: var(--radius-md); overflow: hidden; }
  .collision-card__header { background: #fef2f2; padding: var(--spacing-3) var(--spacing-4); border-block-end: 1px solid #fca5a5; }
  .conflict-badge { display: inline-flex; align-items: center; gap: var(--spacing-2); font-size: var(--text-xs); font-weight: 700; color: #991b1b; }
  .conflict-badge svg { width: 1rem; height: 1rem; }

  .collision-card__comparison { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--spacing-4); padding: var(--spacing-5); align-items: start; }
  @media (max-width: 560px) { .collision-card__comparison { grid-template-columns: 1fr; } .vs-sep { text-align: center; } }

  .person-col { display: grid; gap: 0.2rem; }
  .person-col__role { margin: 0; font-size: var(--text-2xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-tertiary); }
  .person-col__name { margin: 0; font-size: var(--text-sm); font-weight: 700; color: var(--color-text-primary); }
  .person-col__detail { margin: 0; font-size: var(--text-xs); color: var(--color-text-secondary); font-family: monospace; }
  .person-col__detail.highlight { color: #991b1b; background: #fee2e2; padding: 0.1rem 0.3rem; border-radius: 0.2rem; display: inline; font-weight: 700; }

  .vs-sep { display: flex; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: 800; color: var(--color-text-tertiary); letter-spacing: 0.05em; padding-block-start: 1.4rem; }

  .collision-card__actions { display: flex; gap: var(--spacing-3); padding: var(--spacing-4); border-block-start: 1px solid var(--color-border-subtle); flex-wrap: wrap; }
  .btn { display: inline-block; padding: 0.5rem 1.25rem; border-radius: var(--radius-sm); font-size: var(--text-sm); font-weight: 700; text-decoration: none; cursor: pointer; transition: opacity 0.15s, transform 0.1s; border: 2px solid transparent; }
  .btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .btn--sm { padding: 0.4rem 0.875rem; font-size: var(--text-xs); }
  .btn--primary { background: var(--color-mensa-blue); color: var(--color-text-on-brand); }
  .btn--danger  { background: #dc2626; color: #fff; border-color: #dc2626; }
</style>
