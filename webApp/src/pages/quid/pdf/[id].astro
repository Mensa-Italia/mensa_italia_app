---
/**
 * Quid PDF viewer.
 *
 * Page-level viewer per i numeri di Quid con `isPdf=true`. Server-side
 * recupera il record dalla collection PB `quid_issues` (pubblica) per
 * sapere la `pdf_url` esatta, poi embed nel browser tramite <iframe>
 * (gestisce nativamente il rendering PDF in tutti i browser moderni).
 *
 * Deep-link dalla notifica → `/quid/pdf/{id}` con `id` = ID PB del record.
 */
import AppShell from "../../../layouts/AppShell.astro";
import { listPublicQuidIssues, type PublicQuidIssueRecord } from "../../../lib/publicApi";
import { ArrowLeft } from "lucide-react";

const { id } = Astro.params;
if (!id) return Astro.redirect("/quid");

// Lookup by id from the public list (cheap: ~16 records).
let issue: PublicQuidIssueRecord | null = null;
let fetchError: string | null = null;
try {
  const list = await listPublicQuidIssues();
  // Try numeric `id` from URL: PB id may be a string (record id) OR the numeric `id` field.
  issue = list.find((q) => q.id.toString() === id || String((q as any).number) === id) ?? null;
} catch (err) {
  fetchError = err instanceof Error ? err.message : "Errore di caricamento";
}
---

<AppShell
  title={issue ? `${issue.name} — Quid` : "Quid PDF"}
  pageTitle={issue ? issue.name : "Quid PDF"}
>
  <div class="qpdf">
    <header class="qpdf__head">
      <a href="/quid" class="qpdf__back">
        <ArrowLeft size={14} strokeWidth={1.75} aria-hidden={true} />
        Tutti i numeri
      </a>
      {issue && (
        <div class="qpdf__meta">
          <p class="qpdf__num">Numero {issue.number}</p>
          <h1 class="qpdf__title">{issue.name}</h1>
        </div>
      )}
      {issue?.pdf_url && (
        <a
          href={issue.pdf_url}
          target="_blank"
          rel="noopener"
          download
          class="qpdf__download"
        >
          Scarica PDF ↓
        </a>
      )}
    </header>

    {fetchError && (
      <div class="qpdf__error" role="alert">
        <p><strong>Errore di caricamento</strong></p>
        <p class="qpdf__error-detail">{fetchError}</p>
      </div>
    )}

    {!fetchError && !issue && (
      <div class="qpdf__missing">
        <h2>Numero non trovato</h2>
        <p>Il numero di Quid richiesto non esiste oppure non è disponibile in PDF.</p>
        <a href="/quid" class="qpdf__missing-cta">Torna all'archivio Quid</a>
      </div>
    )}

    {!fetchError && issue && !issue.pdf_url && (
      <div class="qpdf__missing">
        <h2>PDF non disponibile</h2>
        <p>Questo numero è in formato articoli. Aprilo dall'archivio per leggerlo online.</p>
        <a href={`/quid/${issue.id}`} class="qpdf__missing-cta">Apri online →</a>
      </div>
    )}

    {!fetchError && issue?.pdf_url && (
      <div class="qpdf__viewer">
        <iframe
          src={issue.pdf_url}
          title={`Quid ${issue.number} — ${issue.name}`}
          loading="eager"
        />
      </div>
    )}
  </div>
</AppShell>

<style>
  .qpdf { display: grid; gap: var(--spacing-4); min-block-size: calc(100dvh - 110px); }
  .qpdf__head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    padding-block-end: var(--spacing-4);
    border-block-end: 1px solid var(--color-border-subtle);
  }
  .qpdf__back {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .qpdf__back:hover { color: var(--color-text-primary); }
  .qpdf__meta { display: grid; gap: 2px; flex: 1; min-inline-size: 0; }
  .qpdf__num {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-mensa-blue);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .qpdf__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
  }
  .qpdf__download {
    display: inline-flex;
    align-items: center;
    padding: 8px var(--spacing-4);
    background: var(--color-mensa-blue);
    color: var(--color-text-on-brand);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .qpdf__download:hover { background: var(--color-mensa-blue-deep); }

  .qpdf__error {
    padding: var(--spacing-4) var(--spacing-5);
    background: color-mix(in oklch, var(--color-status-error) 8%, var(--color-surface));
    border: 1px solid color-mix(in oklch, var(--color-status-error) 30%, var(--color-surface));
    border-radius: var(--radius-md);
  }
  .qpdf__error p { margin: 0; }
  .qpdf__error-detail { color: var(--color-text-tertiary); font-family: var(--font-mono); margin-block-start: var(--spacing-1) !important; font-size: var(--text-xs) !important; }

  .qpdf__missing {
    text-align: center;
    padding-block: var(--spacing-10);
    display: grid;
    gap: var(--spacing-3);
    place-items: center;
  }
  .qpdf__missing h2 { font-family: var(--font-display); margin: 0; font-size: var(--text-lg); color: var(--color-text-primary); }
  .qpdf__missing p { margin: 0; font-size: var(--text-sm); color: var(--color-text-tertiary); max-inline-size: 56ch; }
  .qpdf__missing-cta {
    margin-block-start: var(--spacing-2);
    padding: 10px var(--spacing-5);
    background: var(--color-mensa-blue);
    color: var(--color-text-on-brand);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  .qpdf__viewer {
    flex: 1;
    min-block-size: 75vh;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .qpdf__viewer iframe {
    inline-size: 100%;
    block-size: 100%;
    min-block-size: 75vh;
    border: 0;
    display: block;
  }
</style>
