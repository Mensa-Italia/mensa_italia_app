<script>
  import { countUp } from "../../lib/motion";

  document.querySelectorAll<HTMLElement>('.numbers__value').forEach((el) => {
    const target = Number(el.dataset.count ?? "0");
    if (Number.isNaN(target)) return;
    countUp(el, target, {
      duration: target >= 1000 ? 2.0 : 1.4,
      locale: el.dataset.format === "thousands" ? "it-IT" : "en-US",
    });
  });
</script>
