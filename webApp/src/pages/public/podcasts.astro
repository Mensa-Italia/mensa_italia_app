---
/**
 * Podcast pubblici.
 *
 * Fetch server-side della collection `podcasts` (PB pubblica, no auth).
 * Cover via `pbFileUrl(record, record.image)`. Link diretto a YouTube
 * tramite `youtube_playlist_id`: per ora niente player embedded sul
 * pubblico (riservato alla dashboard via `AudioPlayerService`).
 */
import PublicLayout from "../../layouts/PublicLayout.astro";
import {
  listPublicPodcasts,
  pbFileUrl,
  type PublicPodcastRecord,
} from "../../lib/publicApi";

let podcasts: readonly PublicPodcastRecord[] = [];
let fetchError: string | null = null;
try {
  podcasts = await listPublicPodcasts();
} catch (err) {
  fetchError = err instanceof Error ? err.message : "Errore di caricamento";
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Podcast di Mensa Italia",
  "itemListElement": podcasts.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "PodcastSeries",
      "name": p.title,
      "description": p.description,
      "image": p.image ? pbFileUrl(p, p.image) : undefined,
      "url": p.youtube_playlist_id
        ? `https://www.youtube.com/playlist?list=${p.youtube_playlist_id}`
        : undefined,
    },
  })),
};
---

<PublicLayout
  active="podcasts"
  title="Podcast — Mensa Italia"
  description="I podcast prodotti dai soci di Mensa Italia: Brainwaves, She Talks, Mensa Talk e altri. Ascoltali su YouTube o entra nell'area soci per il player integrato."
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__kicker" data-i18n="web.podcasts.hero.kicker">Podcast</p>
      <h1 class="hero__title" data-i18n="web.podcasts.hero.title">Voci di Mensa Italia.</h1>
      <p class="hero__sub" data-i18n="web.podcasts.hero.sub">
        Conversazioni, interviste, monologhi. I podcast sono prodotti dai soci.
        Ascoltali direttamente nell'app Mensa, su iOS e Android — con player
        integrato, episodi recenti e download offline.
      </p>
    </div>
  </section>

  <section class="list">
    <div class="list__inner">
      {fetchError && (
        <div class="list__error" role="alert">
          <p><strong>Errore di caricamento</strong></p>
          <p class="list__error-detail">{fetchError}</p>
        </div>
      )}

      {!fetchError && podcasts.length === 0 && (
        <div class="list__empty">
          <h2>Nessun podcast disponibile</h2>
          <p>Torna a trovarci tra qualche giorno.</p>
        </div>
      )}

      {!fetchError && podcasts.length > 0 && (
        <ul class="grid">
          {podcasts.map((p) => {
            const cover = p.image ? pbFileUrl(p, p.image) : "";
            const yt = p.youtube_playlist_id
              ? `https://www.youtube.com/playlist?list=${p.youtube_playlist_id}`
              : "";
            return (
              <li>
                <article class="card">
                  {cover ? (
                    <img class="card__cover" src={cover} alt="" loading="lazy" />
                  ) : (
                    <div class="card__cover card__cover--ph" aria-hidden="true" />
                  )}
                  <div class="card__body">
                    <h2 class="card__title">{p.title}</h2>
                    {p.description && <p class="card__desc">{p.description}</p>}
                    <p class="card__meta">
                      {p.episodes_count > 0 && (
                        <span>{p.episodes_count} episodi</span>
                      )}
                    </p>
                    <div class="card__cta">
                      <a
                        class="card__btn"
                        href="https://apps.apple.com/it/app/mensa-italia/id1454987679"
                        target="_blank"
                        rel="noopener"
                      >
                        <span data-i18n="web.podcasts.listen_in_app">Ascolta nell'app Mensa</span>
                      </a>
                      {yt && (
                        <a
                          class="card__btn card__btn--ghost"
                          href={yt}
                          target="_blank"
                          rel="noopener"
                          title="Apri la playlist su YouTube"
                        >
                          <span data-i18n="web.podcasts.youtube_fallback">YouTube</span>
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</PublicLayout>

<style>
  .hero {
    background:
      radial-gradient(60% 50% at 50% 0%, color-mix(in oklch, var(--color-mensa-cyan) 12%, transparent), transparent 70%),
      var(--color-surface);
    padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-10));
    text-align: center;
  }
  .hero__inner {
    max-inline-size: 720px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
    display: grid;
    gap: var(--spacing-3);
  }
  .hero__kicker {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mensa-blue);
  }
  .hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-wrap: balance;
  }
  .hero__sub {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-inline-size: 60ch;
    margin-inline: auto;
  }

  .list { padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-10)); }
  .list__inner {
    max-inline-size: 1200px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
  }
  .list__error {
    padding: var(--spacing-4) var(--spacing-5);
    background: color-mix(in oklch, var(--color-status-error) 8%, var(--color-surface));
    border: 1px solid color-mix(in oklch, var(--color-status-error) 30%, var(--color-surface));
    border-radius: var(--radius-md);
  }
  .list__error p { margin: 0; }
  .list__error-detail { color: var(--color-text-tertiary); font-family: var(--font-mono); margin-block-start: var(--spacing-1) !important; font-size: var(--text-xs); }
  .list__empty { text-align: center; padding-block: var(--spacing-10); color: var(--color-text-tertiary); }
  .list__empty h2 { font-family: var(--font-display); margin: 0; }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    grid-auto-rows: 1fr;
    gap: var(--spacing-5);
    align-items: stretch;
  }
  .grid > li {
    display: flex;
    align-self: stretch;
    block-size: 100%;
    min-block-size: 0;
  }
  .card {
    inline-size: 100%;
    block-size: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr;
  }
  .card__cover {
    aspect-ratio: 1 / 1;
    inline-size: 100%;
    object-fit: cover;
    background: var(--color-surface-sunken);
  }
  .card__cover--ph {
    background:
      linear-gradient(135deg,
        color-mix(in oklch, var(--color-mensa-blue) 22%, var(--color-surface)),
        color-mix(in oklch, var(--color-mensa-cyan) 22%, var(--color-surface)));
  }
  .card__body {
    padding: var(--spacing-4) var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    block-size: 100%;
  }
  .card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }
  .card__desc {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__meta {
    margin: 0;
    font-size: var(--text-2xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .card__cta { margin-block-start: auto; padding-block-start: var(--spacing-3); display: flex; flex-wrap: wrap; gap: var(--spacing-2); }
  .card__btn {
    display: inline-flex;
    align-items: center;
    padding: 8px var(--spacing-4);
    background: var(--color-mensa-blue);
    color: var(--color-text-on-brand);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .card__btn:hover { background: var(--color-mensa-blue-deep); }
  .card__btn--ghost {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-strong);
  }
  .card__btn--ghost:hover { background: var(--color-surface-elevated); }
</style>
