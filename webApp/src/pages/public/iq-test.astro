---
import PublicLayout from "../../layouts/PublicLayout.astro";
import { IqTestApp } from "../../components/public/IqTestApp";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);
const cms = await reader.singletons.iqtest.read();

const heroKicker = cms?.heroKicker ?? "Test di prova";
const heroTitle = cms?.heroTitle ?? "Mettiti alla prova.";
const heroSubtitle = cms?.heroSubtitle ?? "35 matrici figurative, 20–25 minuti. Identico al test ufficiale di esempio di Mensa Norge — Mensa Italia fa solo da contenitore grafico.";
---

<PublicLayout
  active="test-qi"
  title="Test del QI — Mensa Italia"
  description="Prova un test ufficiale di esempio realizzato da Mensa Norge: 35 matrici figurative, 20–25 minuti, risultato in IQ e percentile."
>
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__kicker" data-i18n="iqtest.title">{heroKicker}</p>
      <h1 class="hero__title" data-i18n="web.iqtest.hero.title">{heroTitle}</h1>
      <p class="hero__sub" data-i18n="web.iqtest.hero.sub">{heroSubtitle}</p>
    </div>
  </section>

  <IqTestApp client:load />
</PublicLayout>

<style>
  .hero {
    background:
      radial-gradient(60% 50% at 50% 0%, color-mix(in oklch, var(--color-mensa-cyan) 10%, transparent), transparent 70%),
      var(--color-surface);
    padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-10));
    text-align: center;
  }
  .hero__inner {
    max-inline-size: 720px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
    display: grid;
    gap: var(--spacing-3);
  }
  .hero__kicker {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mensa-blue);
  }
  .hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-wrap: balance;
  }
  .hero__sub {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-inline-size: 56ch;
    margin-inline: auto;
  }
</style>
