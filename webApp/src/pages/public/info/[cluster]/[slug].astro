---
import PublicLayout from "../../../../layouts/PublicLayout.astro";
import StaticPageBody from "../../../../components/public/StaticPageBody.astro";
import {
  CLUSTERS,
  type ClusterSlug,
  loadAllStaticPages,
  loadPage,
  pageHref,
  clusterHubHref,
} from "../../../../lib/staticPages";

export const prerender = true;

export async function getStaticPaths() {
  const all = await loadAllStaticPages();
  return all.map((p) => ({
    params: { cluster: p.cluster, slug: p.pageSlug },
    props: { entry: p },
  }));
}

const { cluster, slug } = Astro.params as { cluster: ClusterSlug; slug: string };
const meta = CLUSTERS[cluster];
const entry = await loadPage(cluster, slug);

if (!meta || !entry) {
  return Astro.redirect("/public/about");
}

const body = await entry.body();
const rootNode: any = (body as any)?.node ?? body;
const nodes: any[] = (rootNode?.children as any[]) ?? [];

// ── Reading-time estimate ────────────────────────────────────────────────────
function countWords(n: any): number {
  if (n?.attributes?.content) return String(n.attributes.content).split(/\s+/).filter(Boolean).length;
  return (n?.children ?? []).reduce((s: number, c: any) => s + countWords(c), 0);
}
const totalWords = nodes.reduce((s, n) => s + countWords(n), 0);
const readingMin = Math.max(1, Math.round(totalWords / 200));

// ── TOC: extract H2 nodes ────────────────────────────────────────────────────
interface TocItem { text: string; id: string }

function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/[àáâãäå]/g, "a").replace(/[èéêë]/g, "e")
    .replace(/[ìíîï]/g, "i").replace(/[òóôõö]/g, "o")
    .replace(/[ùúûü]/g, "u").replace(/[ç]/g, "c").replace(/[ñ]/g, "n")
    .replace(/[^a-z0-9\s-]/g, "").replace(/\s+/g, "-").replace(/-+/g, "-").replace(/^-|-$/g, "");
}

function nodeText(n: any): string {
  if (n?.attributes?.content) return String(n.attributes.content);
  return (n?.children ?? []).map(nodeText).join("");
}

const tocItems: TocItem[] = [];
const idCounts: Record<string, number> = {};
for (const n of nodes) {
  if (n.type === "heading" && Number(n.attributes?.level ?? 0) === 2) {
    const text = nodeText(n).trim();
    if (text) {
      let id = slugify(text) || `h2-${tocItems.length}`;
      idCounts[id] = (idCounts[id] ?? 0) + 1;
      if (idCounts[id] > 1) id = `${id}-${idCounts[id]}`;
      tocItems.push({ text, id });
    }
  }
}
// TOC only when there's enough structure to justify it — 1-min reads with 3
// H2s rarely need navigation, the chip card just adds noise.
const showToc = tocItems.length >= 4;

// ── Inject IDs into H2 nodes for anchor linking ──────────────────────────────
// We re-walk nodes and mutate attributes so the renderer picks them up.
// Reset counter to match TOC generation order.
const idCountsRender: Record<string, number> = {};
for (const n of nodes) {
  if (n.type === "heading" && Number(n.attributes?.level ?? 0) === 2) {
    const text = nodeText(n).trim();
    if (text) {
      let id = slugify(text) || "h2";
      idCountsRender[id] = (idCountsRender[id] ?? 0) + 1;
      if (idCountsRender[id] > 1) id = `${id}-${idCountsRender[id]}`;
      n.attributes = { ...(n.attributes ?? {}), id };
    }
  }
}

const allPages = (await loadAllStaticPages()).filter((p) => p.cluster === cluster);
const currentIdx = allPages.findIndex((p) => p.pageSlug === slug);
const prev = currentIdx > 0 ? allPages[currentIdx - 1] : null;
const next = currentIdx >= 0 && currentIdx < allPages.length - 1 ? allPages[currentIdx + 1] : null;

const docTitle = entry.seoTitle?.trim() || `${entry.title} — Mensa Italia`;
const docDesc =
  entry.seoDescription?.trim() ||
  entry.intro?.trim() ||
  `${entry.title}. Sezione ${meta.label} di Mensa Italia.`;

const kicker = `${(entry.kicker?.trim() || meta.label)} · ${readingMin} min di lettura`;
---

<PublicLayout
  active={cluster === "chi-siamo" ? "chi-siamo" : undefined}
  title={docTitle}
  description={docDesc}
>
  <!-- ═══ BREADCRUMB ════════════════════════════════════════════ -->
  <nav class="crumbs" aria-label="Breadcrumb">
    <div class="crumbs__inner">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href={clusterHubHref(cluster)}>{meta.label}</a>
      <span aria-hidden="true">/</span>
      <span class="crumbs__current" aria-current="page">{entry.title}</span>
    </div>
  </nav>

  <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__kicker">{kicker}</p>
      <h1 class="hero__title">{entry.title}</h1>
    </div>
  </section>

  <!-- ═══ CONTENT ════════════════════════════════════════════════ -->
  <div class={`content-wrap${showToc ? " content-wrap--toc" : ""}`}>
    <div class="content-wrap__inner">

      {showToc && (
        <aside class="toc" aria-label="Indice della pagina">
          <p class="toc__label">In questa pagina</p>
          <nav>
            <ol class="toc__list">
              {tocItems.map((item, i) => (
                <li>
                  <a href={`#${item.id}`} class="toc__link">{item.text}</a>
                  {i < tocItems.length - 1 && (
                    <span class="toc__sep" aria-hidden="true">·</span>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

      <article class="prose">
        <StaticPageBody
          nodes={nodes}
          dropFirstParagraphIfMatches={entry.intro?.trim() || undefined}
        />

      </article>

    </div>
  </div>

  <!-- ═══ PREV / NEXT ═══════════════════════════════════════════ -->
  {(prev || next) && (
    <nav class="adj" aria-label="Altre pagine in questo capitolo">
      <div class="adj__inner">
        <div class="adj__divider" role="presentation" />
        <div class="adj__links">
          {prev ? (
            <a class="adj__link adj__link--prev" href={pageHref(prev.cluster, prev.pageSlug)}>
              <span class="adj__label">← Prima</span>
              <span class="adj__title">{prev.title}</span>
            </a>
          ) : <span />}
          {next ? (
            <a class="adj__link adj__link--next" href={pageHref(next.cluster, next.pageSlug)}>
              <span class="adj__label">Dopo →</span>
              <span class="adj__title">{next.title}</span>
            </a>
          ) : <span />}
        </div>
      </div>
    </nav>
  )}
</PublicLayout>

<style>
  /* ── breadcrumb ───────────────────────────────────────────────── */
  .crumbs {
    border-block-end: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
  }
  .crumbs__inner {
    max-inline-size: 1200px;
    margin-inline: auto;
    padding: var(--spacing-3) clamp(var(--spacing-4), 5vw, var(--spacing-8));
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    font-size: var(--text-2xs);
    color: var(--color-text-tertiary);
  }
  .crumbs__inner a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--motion-fast) var(--ease-out-quart);
  }
  .crumbs__inner a:hover { color: var(--color-mensa-blue); }
  .crumbs__current { color: var(--color-text-primary); font-weight: 500; }
  .crumbs__inner span[aria-hidden] { color: var(--color-text-tertiary); }

  /* ── hero ─────────────────────────────────────────────────────── */
  .hero {
    background:
      radial-gradient(55% 40% at 50% 0%, color-mix(in oklch, var(--color-mensa-cyan) 10%, transparent), transparent 70%),
      var(--color-surface);
    padding-block: clamp(var(--spacing-6), 6vh, var(--spacing-10));
    text-align: center;
  }
  .hero__inner {
    max-inline-size: 680px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
    display: grid;
    gap: var(--spacing-3);
  }
  .hero__kicker {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mensa-blue);
  }
  .hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    text-wrap: balance;
  }

  /* ── content wrapper (1-col / 2-col with TOC) ─────────────────── */
  .content-wrap {
    background: var(--color-surface);
    padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-14));
  }
  .content-wrap__inner {
    max-inline-size: 800px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
  }

  /* When TOC is present, switch to two-column */
  .content-wrap--toc .content-wrap__inner {
    max-inline-size: 1200px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: clamp(var(--spacing-8), 5vw, var(--spacing-14));
    align-items: start;
  }

  /* ── TOC ──────────────────────────────────────────────────────── */
  .toc {
    position: sticky;
    top: var(--spacing-8);
  }
  .toc__label {
    margin: 0 0 var(--spacing-3) 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-tertiary);
  }
  .toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    border-inline-start: 1px solid var(--color-border-subtle);
  }
  .toc__link {
    display: block;
    padding: var(--spacing-2) var(--spacing-3);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-decoration: none;
    line-height: 1.4;
    border-inline-start: 2px solid transparent;
    margin-inline-start: -1px;
    transition: color var(--motion-fast) var(--ease-out-quart),
                border-color var(--motion-fast) var(--ease-out-quart);
  }
  .toc__link:hover {
    color: var(--color-text-primary);
    border-inline-start-color: var(--color-mensa-blue);
  }
  .toc__sep { display: none; }

  /* ── prose column ─────────────────────────────────────────────── */
  .prose {
    max-inline-size: 65ch;
    min-inline-size: 0; /* prevent grid blowout */
    /* Long unbreakable strings (URLs, tokens) in imported WP content must
       wrap to viewport width instead of blowing out the page horizontally
       on mobile. `anywhere` lets the browser break inside the word as a
       last resort while keeping normal word-wrap elsewhere. */
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .prose :global(a),
  .prose :global(code),
  .prose :global(pre) {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* Lead paragraph */
  .prose :global(.lead) {
    margin: 0 0 var(--spacing-5) 0;
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.65;
  }

  /* Body paragraphs */
  .prose :global(p) {
    margin: 0 0 var(--spacing-4) 0;
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  /* H2 — section break with line above */
  .prose :global(h2) {
    margin: var(--spacing-10) 0 var(--spacing-4) 0;
    padding-block-start: var(--spacing-6);
    border-block-start: 1px solid var(--color-border-subtle);
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    line-height: 1.15;
  }
  /* First H2 in the article — no top border/padding even if a lead paragraph
     precedes it (in which case :first-child wouldn't match). */
  .prose :global(h2:first-child),
  .prose :global(h2:first-of-type) {
    margin-block-start: 0;
    padding-block-start: 0;
    border-block-start: none;
  }

  /* H3 — quieter */
  .prose :global(h3) {
    margin: var(--spacing-7) 0 var(--spacing-2) 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text-secondary);
    line-height: 1.25;
  }

  /* H4 */
  .prose :global(h4) {
    margin: var(--spacing-5) 0 var(--spacing-2) 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Links */
  .prose :global(a) {
    color: var(--color-mensa-blue);
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: opacity var(--motion-fast) var(--ease-out-quart);
  }
  .prose :global(a:hover) { opacity: 0.75; }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--spacing-4) 0;
    padding-inline-start: var(--spacing-6);
    color: var(--color-text-secondary);
    line-height: 1.85;
  }
  .prose :global(li) { margin-block-end: var(--spacing-2); }
  .prose :global(li > ul),
  .prose :global(li > ol) { margin-block-start: var(--spacing-2); }
  .prose :global(strong) { color: var(--color-text-primary); font-weight: 600; }

  /* Pull-quote blockquote */
  .prose :global(blockquote) {
    margin: var(--spacing-7) 0;
    padding: var(--spacing-1) 0 var(--spacing-1) var(--spacing-5);
    border-inline-start: 3px solid var(--color-mensa-blue);
    background: transparent;
  }
  .prose :global(blockquote p) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.45;
    margin-block-end: 0;
  }
  .prose :global(blockquote p:last-child) { margin-block-end: 0; }

  /* HR */
  .prose :global(hr) {
    margin: var(--spacing-8) 0;
    border: 0;
    border-block-start: 1px solid var(--color-border-subtle);
  }

  /* Images */
  .prose :global(img) {
    max-inline-size: 100%;
    height: auto;
    border-radius: var(--radius-md);
  }
  .prose :global(figure) { margin: var(--spacing-6) 0; }
  .prose :global(figcaption) {
    margin-block-start: var(--spacing-2);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-align: center;
  }

  /* Code */
  .prose :global(code) {
    font-size: 0.875em;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }
  .prose :global(pre) {
    margin: 0 0 var(--spacing-4) 0;
    padding: var(--spacing-4);
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  /* Source attribution line */
  .source-line {
    margin-block-start: var(--spacing-8);
    padding-block-start: var(--spacing-5);
    border-block-start: 1px solid var(--color-border-subtle);
    font-size: var(--text-2xs);
    color: var(--color-text-tertiary);
  }
  .source-line a {
    color: var(--color-text-tertiary);
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }
  .source-line a:hover { color: var(--color-mensa-blue); }

  /* ── inline TOC on narrow viewports ──────────────────────────── */
  /* No card, no chips: a single quiet line "In questa pagina: A · B · C". */
  @media (max-width: 1023px) {
    .content-wrap--toc .content-wrap__inner {
      grid-template-columns: 1fr;
    }
    .toc {
      position: static;
      padding: 0;
      background: transparent;
      border: none;
      margin-block-end: var(--spacing-6);
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: var(--spacing-2) var(--spacing-1);
    }
    .toc__label {
      margin: 0;
      flex-shrink: 0;
    }
    .toc__list {
      border-inline-start: none;
      display: inline-flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: var(--spacing-2);
      padding: 0;
    }
    .toc__list li {
      display: inline-flex;
      align-items: baseline;
      gap: var(--spacing-2);
    }
    .toc__link {
      display: inline;
      padding: 0;
      border: none;
      margin: 0;
      font-size: var(--text-xs);
      color: var(--color-mensa-blue);
      text-decoration: none;
    }
    .toc__link:hover {
      color: var(--color-text-primary);
      border: none;
    }
    .toc__sep {
      display: inline;
      color: var(--color-text-tertiary);
      font-size: var(--text-xs);
    }
  }

  /* ── prev / next ──────────────────────────────────────────────── */
  .adj {
    background: var(--color-surface);
    padding-block: clamp(var(--spacing-6), 5vh, var(--spacing-10));
  }
  .adj__inner {
    max-inline-size: 800px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
  }
  .adj__divider {
    border-block-start: 1px solid var(--color-border-subtle);
    margin-block-end: clamp(var(--spacing-5), 4vh, var(--spacing-8));
  }
  .adj__links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-4);
  }
  @media (max-width: 600px) {
    .adj__links { grid-template-columns: 1fr; }
  }
  .adj__link {
    display: grid;
    gap: var(--spacing-1);
    text-decoration: none;
    color: inherit;
    padding: var(--spacing-2) 0;
    transition: opacity var(--motion-fast) var(--ease-out-quart);
  }
  .adj__link:hover { opacity: 0.7; }
  .adj__link--next { text-align: end; }
  .adj__label {
    font-size: var(--text-2xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .adj__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
  }
</style>
