---
import PublicLayout from "../../layouts/PublicLayout.astro";
import {
  listPublicLocalOffices,
  pbFileUrl,
  type PublicLocalOfficeRecord,
} from "../../lib/publicApi";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../../keystatic.config";

let offices: readonly PublicLocalOfficeRecord[] = [];
let fetchError: string | null = null;
try {
  offices = await listPublicLocalOffices();
} catch (err) {
  fetchError = err instanceof Error ? err.message : "Errore di caricamento";
}

const reader = createReader(process.cwd(), keystaticConfig);
const cms = await reader.singletons.chapters.read();

const heroKicker = cms?.heroKicker ?? "Gruppi locali";
const heroTitle = cms?.heroTitle ?? "Una comunità che si incontra davvero, vicino a te.";
const heroSubtitle = cms?.heroSubtitle ?? "Venti gruppi sul territorio nazionale, dal Trentino alla Sicilia. Ognuno organizza cene mensili, conferenze, gite, weekend di giochi, gruppi di lettura. Ognuno ha un proprio team di referenti volontari.";
const ctaKicker = cms?.ctaKicker ?? "Vuoi unirti?";
const ctaTitle = cms?.ctaTitle ?? "Ogni socio appartiene al gruppo della sua regione.";
const ctaBody = cms?.ctaBody ?? "Una volta diventato socio, sei automaticamente parte del gruppo della tua regione. Puoi comunque partecipare alle attività di tutti gli altri gruppi: la tessera è una sola per tutta Italia.";
---

<PublicLayout
  active="gruppi"
  title="Gruppi locali — Mensa Italia"
  description="Venti gruppi locali Mensa Italia in tutta la penisola. Cene mensili, conferenze, gite, weekend di giochi — la vita di una comunità che si incontra davvero."
>
  <section class="hero">
    <div class="hero__inner">
      <p class="hero__kicker" data-i18n="web.local_offices.hero.kicker">{heroKicker}</p>
      <h1 class="hero__title" data-i18n="web.local_offices.hero.title">{heroTitle}</h1>
      <p class="hero__sub" data-i18n="web.local_offices.hero.sub">{heroSubtitle}</p>
    </div>
  </section>

  <section class="list">
    <div class="list__inner">
      {fetchError && (
        <div class="list__error" role="alert">
          <p><strong data-i18n="web.common.fetch_error">Errore di caricamento</strong></p>
          <p class="list__error-detail">{fetchError}</p>
        </div>
      )}

      {!fetchError && offices.length === 0 && (
        <div class="list__empty">
          <h2 data-i18n="web.local_offices.empty.title">Nessun gruppo locale disponibile</h2>
          <p data-i18n="web.local_offices.empty.body">Riprova fra qualche minuto.</p>
        </div>
      )}

      {!fetchError && offices.length > 0 && (
        <ul class="cards">
          {offices.map((o) => {
            const cover = o.image ? pbFileUrl(o, o.image) : "";
            const showRegion = o.region && o.region !== o.name;
            return (
              <li>
                <a class="card" href={`/public/chapters/${o.slug}`}>
                  {cover ? (
                    <img class="card__cover" src={cover} alt="" loading="lazy" />
                  ) : (
                    <div class="card__cover card__cover--placeholder" aria-hidden="true" />
                  )}
                  <div class="card__body">
                    {showRegion && <p class="card__region">{o.region}</p>}
                    <h2 class="card__name">{o.name}</h2>
                    {o.bio && <p class="card__bio">{o.bio}</p>}
                    <p class="card__cta">
                      <span data-i18n="web.local_offices.card.cta">Scopri il gruppo</span>
                      <svg viewBox="0 0 24 24" width={14} height={14} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M5 12h14M13 5l7 7-7 7"/>
                      </svg>
                    </p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  <section class="cta">
    <div class="cta__inner">
      <p class="cta__kicker" data-i18n="web.local_offices.cta.kicker">{ctaKicker}</p>
      <h2 data-i18n="web.local_offices.cta.title">{ctaTitle}</h2>
      <p data-i18n="web.local_offices.cta.body">{ctaBody}</p>
      <div class="cta__btns">
        <a href="/public/iq-test" class="cta__btn cta__btn--primary" data-i18n="web.common.cta.try_test">Mettiti alla prova</a>
        <a href="/public/about" class="cta__btn cta__btn--ghost" data-i18n="web.common.cta.how_to_join">Come si entra</a>
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .hero {
    background:
      radial-gradient(60% 50% at 50% 0%, color-mix(in oklch, var(--color-mensa-cyan) 12%, transparent), transparent 70%),
      var(--color-surface);
    padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-10));
    text-align: center;
  }
  .hero__inner {
    max-inline-size: 760px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
    display: grid;
    gap: var(--spacing-3);
  }
  .hero__kicker {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mensa-blue);
  }
  .hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    text-wrap: balance;
  }
  .hero__sub {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-inline-size: 60ch;
    margin-inline: auto;
  }

  .list { padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-10)); }
  .list__inner {
    max-inline-size: 1200px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
  }
  .list__error {
    padding: var(--spacing-4) var(--spacing-5);
    background: color-mix(in oklch, var(--color-status-error) 8%, var(--color-surface));
    border: 1px solid color-mix(in oklch, var(--color-status-error) 30%, var(--color-surface));
    border-radius: var(--radius-md);
  }
  .list__error p { margin: 0; font-size: var(--text-sm); color: var(--color-text-primary); }
  .list__error-detail { color: var(--color-text-tertiary); font-family: var(--font-mono); margin-block-start: var(--spacing-1) !important; font-size: var(--text-xs) !important; }
  .list__empty {
    text-align: center;
    padding-block: var(--spacing-10);
    color: var(--color-text-tertiary);
  }
  .list__empty h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--spacing-5);
  }
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--motion-fast) var(--ease-out-quart),
                transform var(--motion-fast) var(--ease-out-quart);
  }
  .card:hover {
    border-color: var(--color-mensa-blue);
    transform: translateY(-2px);
  }
  .card__cover {
    aspect-ratio: 16 / 9;
    inline-size: 100%;
    object-fit: cover;
    background: var(--color-surface-sunken);
  }
  .card__cover--placeholder {
    background:
      linear-gradient(135deg,
        color-mix(in oklch, var(--color-mensa-blue) 22%, var(--color-surface)),
        color-mix(in oklch, var(--color-mensa-cyan) 22%, var(--color-surface)));
  }
  .card__body {
    padding: var(--spacing-4) var(--spacing-5);
    display: grid;
    gap: var(--spacing-2);
  }
  .card__region {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .card__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  .card__bio {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__cta {
    margin: var(--spacing-2) 0 0 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-mensa-blue);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .cta {
    border-block-start: 1px solid var(--color-border-subtle);
    padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-10));
    background: var(--color-surface-elevated);
    text-align: center;
  }
  .cta__inner {
    max-inline-size: 720px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
    display: grid;
    gap: var(--spacing-3);
  }
  .cta__kicker {
    margin: 0;
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .cta h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(var(--text-lg), 3vw, var(--text-xl));
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    text-wrap: balance;
  }
  .cta p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .cta__btns {
    margin-block-start: var(--spacing-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    justify-content: center;
  }
  .cta__btn {
    display: inline-flex;
    align-items: center;
    padding: 10px var(--spacing-5);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .cta__btn--primary {
    background: var(--color-mensa-blue);
    color: var(--color-text-on-brand);
  }
  .cta__btn--primary:hover { background: var(--color-mensa-blue-deep); }
  .cta__btn--ghost {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-strong);
  }
  .cta__btn--ghost:hover { background: var(--color-surface); }
</style>
