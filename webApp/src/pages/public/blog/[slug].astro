---
import PublicLayout from "../../../layouts/PublicLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../../../keystatic.config";

const { slug } = Astro.params;

const reader = createReader(process.cwd(), keystaticConfig);
const item = await reader.collections.news.read(slug!);

if (!item) return Astro.redirect("/public/blog");

const bodyRaw: any = await item.body();
const bodyChildren: any[] = Array.isArray(bodyRaw)
  ? bodyRaw
  : Array.isArray(bodyRaw?.children)
    ? bodyRaw.children
    : Array.isArray(bodyRaw?.node?.children)
      ? bodyRaw.node.children
      : [];

function formatDate(d: string | null | undefined) {
  if (!d) return "";
  return new Date(d).toLocaleDateString("it-IT", { year: "numeric", month: "long", day: "numeric" });
}
---

<PublicLayout
  title={`${item.title} — Mensa Italia`}
  description={item.excerpt ?? undefined}
>
  <article class="blog-article">
    <div class="blog-article__inner">
      <a class="blog-article__back" href="/public/blog">← Tutti gli articoli</a>

      <header class="blog-article__header">
        {item.publishedAt && (
          <time class="blog-article__date" datetime={item.publishedAt}>
            {formatDate(item.publishedAt)}
          </time>
        )}
        <h1 class="blog-article__title">{item.title}</h1>
        {item.excerpt && <p class="blog-article__excerpt">{item.excerpt}</p>}
      </header>

      <div class="blog-article__body prose">
        {bodyChildren.map((node: any) => {
          if (node.type === "paragraph") {
            return <p>{node.children?.map((c: any) => c.text ?? "").join("")}</p>;
          }
          if (node.type === "heading") {
            const text = node.children?.map((c: any) => c.text ?? "").join("") ?? "";
            if (node.level === 2) return <h2>{text}</h2>;
            if (node.level === 3) return <h3>{text}</h3>;
            return <h4>{text}</h4>;
          }
          if (node.type === "unordered-list") {
            return (
              <ul>
                {node.children?.map((li: any) => (
                  <li>{li.children?.flatMap((c: any) => c.children ?? [c]).map((c: any) => c.text ?? "").join("")}</li>
                ))}
              </ul>
            );
          }
          return null;
        })}
      </div>
    </div>
  </article>
</PublicLayout>

<style>
  .blog-article {
    padding-block: clamp(var(--spacing-8), 8vh, var(--spacing-12));
  }
  .blog-article__inner {
    max-inline-size: 720px;
    margin-inline: auto;
    padding-inline: clamp(var(--spacing-4), 5vw, var(--spacing-8));
  }
  .blog-article__back {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-mensa-blue);
    text-decoration: none;
  }
  .blog-article__back:hover { text-decoration: underline; }

  .blog-article__header {
    margin-block: var(--spacing-6) var(--spacing-8);
    display: grid;
    gap: var(--spacing-3);
  }
  .blog-article__date {
    font-size: var(--text-2xs);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .blog-article__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 5vw, var(--text-3xl));
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text-primary);
  }
  .blog-article__excerpt {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .blog-article__body.prose {
    color: var(--color-text-secondary);
    line-height: 1.75;
  }
  .blog-article__body.prose h2 {
    margin: var(--spacing-6) 0 var(--spacing-3);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
  }
  .blog-article__body.prose h3 {
    margin: var(--spacing-5) 0 var(--spacing-2);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .blog-article__body.prose p { margin: 0 0 var(--spacing-4); }
  .blog-article__body.prose ul { margin: 0 0 var(--spacing-4) var(--spacing-6); }
  .blog-article__body.prose li { margin-block-end: var(--spacing-1); }
</style>
